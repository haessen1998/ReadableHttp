{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.readablehttp.dev/readable-environment.schema.json",
  "title": "ReadableHttp Environment",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "default": "1.0"
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "variables": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/variable"
      },
      "default": {}
    }
  },
  "required": [
    "name",
    "variables"
  ],
  "$defs": {
    "variable": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "value": {
          "type": [
            "string",
            "number",
            "boolean",
            "object",
            "array",
            "null"
          ]
        },
        "type": {
          "type": "string",
          "enum": [
            "string",
            "number",
            "boolean",
            "json"
          ],
          "default": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "fixed",
            "expression",
            "ai"
          ],
          "default": "fixed"
        },
        "expression": {
          "type": [
            "string",
            "null"
          ]
        },
        "ai": {
          "$ref": "#/$defs/aiVariableOptions"
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "value"
      ]
    },
    "aiVariableOptions": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true,
      "properties": {
        "purpose": {
          "type": [
            "string",
            "null"
          ]
        },
        "prompt": {
          "type": [
            "string",
            "null"
          ]
        },
        "businessMeaning": {
          "type": [
            "string",
            "null"
          ]
        },
        "avoidPreviouslyUsedValues": {
          "type": "boolean",
          "default": true
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    }
  }
}
