{
  "name": "GET with query and headers",
  "method": "GET",
  "url": "{{baseUrl}}/get",
  "query": [
    {
      "name": "page",
      "value": "1",
      "enabled": true
    },
    {
      "name": "keyword",
      "value": "readable-http",
      "enabled": true
    }
  ],
  "headers": [
    {
      "name": "accept",
      "value": "application/json",
      "enabled": true
    },
    {
      "name": "x-sample",
      "value": "get-with-query",
      "enabled": true
    }
  ]
}
