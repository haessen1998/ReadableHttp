@page "/"
@implements IDisposable
@inject ApiClientWorkspaceState State

<PageTitle>ReadableHttp</PageTitle>

<RequestWorkspace Method="@State.Method"
                  MethodChanged="@State.SetMethod"
                  Url="@State.Url"
                  UrlChanged="@State.SetUrl"
                  BodyText="@State.BodyText"
                  BodyTextChanged="@State.SetBodyText"
                  OnFormatBody="@State.FormatBody"
                  BodyType="@State.BodyType"
                  BodyTypeChanged="@State.SetBodyType"
                  BodyContentType="@State.BodyContentType"
                  BodyContentTypeChanged="@State.SetBodyContentType"
                  RequestQuery="@State.RequestQuery"
                  RequestHeaders="@State.RequestHeaders"
                  RequestForm="@State.RequestForm"
                  OnAddNameValue="@State.AddNameValue"
                  OnSetNameValue="@State.SetNameValue"
                  OnRemoveNameValue="@State.RemoveNameValue"
                  IsSending="@State.IsSending"
                  ViewMode="@State.ViewMode"
                  RawContent="@State.RawContent"
                  RequestTab="@State.RequestTab"
                  RequestName="@State.RequestName"
                  RequestNameChanged="@State.SetRequestName"
                  WorkspaceName="@State.WorkspaceName"
                  WorkspaceNameChanged="@State.SetWorkspaceName"
                  WorkspaceTypeLabel="@State.WorkspaceTypeLabel"
                  WorkspaceVariables="@State.WorkspaceVariables"
                  CollectionVariables="@State.CollectionVariables"
                  OnAddVariable="@State.AddVariable"
                  OnSetVariable="@State.SetVariable"
                  OnRemoveVariable="@State.RemoveVariable"
                  WorkspaceRemoteUrl="@State.WorkspaceRemoteUrl"
                  WorkspaceRemoteUrlChanged="@State.SetWorkspaceRemoteUrl"
                  WorkspacePath="@State.WorkspacePath"
                  CollectionCount="@State.Collections.Count"
                  SpecificationCount="@State.VisibleSpecificationCount"
                  CollectionName="@(State.SelectedCollection?.Name ?? "Collection")"
                  CollectionNameChanged="@State.SetCollectionName"
                  CollectionSource="@(State.SelectedCollection?.SourceType.ToString() ?? "Local")"
                  CollectionRequestDirectory="@State.CollectionRequestDirectory"
                  CollectionRequestDirectoryChanged="@State.SetCollectionRequestDirectory"
                  CollectionRequestCount="@(State.SelectedCollection?.Requests.Count ?? 0)"
                  SpecificationName="@State.SpecificationName"
                  SpecificationNameChanged="@State.SetSpecificationName"
                  SpecificationSourceLabel="@State.SpecificationSourceLabel"
                  SpecificationEndpoint="@State.SpecificationEndpoint"
                  SpecificationEndpointChanged="@State.SetSpecificationEndpoint"
                  SpecificationPath="@State.SpecificationPath"
                  SpecificationCachePath="@State.SpecificationCachePath"
                  SpecificationCacheStatus="@State.SpecificationCacheStatus"
                  SpecificationLastRefreshedLabel="@State.SpecificationLastRefreshedLabel"
                  ActiveSource="@State.ActiveSource"
                  DocumentTitle="@State.DocumentTitle"
                  OperationCount="@State.Operations.Count"
                  UseSystemProxy="@State.UseSystemProxy"
                  ProxyMode="@State.ProxyMode"
                  ResponseNodePath="@State.ResponseNodePath"
                  StatusClass="@State.StatusClass"
                  StatusText="@State.StatusText"
                  ResponseText="@State.ResponseText"
                  PipelineTotalLabel="@State.PipelineTotalLabel"
                  PipelinePhases="@State.PipelinePhases"
                  ResponseNodeKeys="@State.ResponseNodeKeys"
                  SelectedResponseText="@State.SelectedResponseText"
                  RequestTabs="@State.RequestTabs"
                  ActiveRequestTabId="@State.ActiveRequestTabId"
                  PendingCloseTabId="@State.PendingCloseTabId"
                  ActiveRequestOrigin="@State.ActiveRequestTab?.Origin"
                  AboutDescription="@State.AboutDescription"
                  AboutStats="@State.AboutStats"
                  SettingsDraft="@State.SettingsDraft"
                  T="@State.T"
                  OnSend="@State.SendAsync"
                  OnSaveRequest="@State.SaveActiveRequestAsync"
                  OnSaveRequestAsNew="@State.SaveActiveRequestAsNewAsync"
                  OnSaveWorkspaceConfig="@State.SaveWorkspaceAsync"
                  OnSaveCollectionConfig="@State.SaveWorkspaceAsync"
                  OnSaveSpecificationConfig="@State.SaveSpecificationAsync"
                  OnRefreshSpecificationConfig="@State.RefreshSelectedSpecificationAsync"
                  OnSaveSettings="@State.SaveSettings"
                  ThemeModeChanged="@State.SetDraftThemeMode"
                  ProxyModeChanged="@State.SetDraftProxyMode"
                  CustomProxyUrlChanged="@State.SetDraftCustomProxyUrl"
                  CustomProxyUsernameChanged="@State.SetDraftCustomProxyUsername"
                  CustomProxyPasswordChanged="@State.SetDraftCustomProxyPassword"
                  DevToolsEnabledChanged="@State.SetDraftDevToolsEnabled"
                  LanguageChanged="@State.SetDraftLanguage"
                  FontSizeChanged="@State.SetDraftFontSize"
                  OnNewScratchRequest="@State.NewScratchRequest"
                  OnPickWorkspace="@State.PickWorkspaceAsync"
                  OnNewCollection="@State.NewCollection"
                  OnPickTryFile="@State.PickTryFileAsync"
                  OnSelectOpenTab="@State.SelectRequestTab"
                  OnCloseOpenTab="@State.CloseRequestTab"
                  OnConfirmCloseOpenTab="@State.ConfirmCloseRequestTab"
                  OnCancelCloseOpenTab="@State.CancelCloseRequestTab"
                  OnSaveOpenTab="@State.SaveRequestTabAsync"
                  OnCloseOtherOpenTabs="@State.CloseOtherRequestTabs"
                  OnCloseAllOpenTabs="@State.CloseAllRequestTabs"
                  OnSetRequestTab="@State.SetRequestTab"
                  OnSelectResponseNode="@State.SelectResponseNode">
    <PreviewContent>
        <SwaggerPreview DocumentTitle="@State.DocumentTitle"
                        TryFilePath="@State.TryFilePath"
                        ActiveSource="@State.ActiveSource"
                        Operations="@State.Operations"
                        ExpandedOperationKey="@State.ExpandedOperationKey"
                        OnShowRaw="@State.ShowRaw"
                        OnLoadTryDocument="@State.LoadTryDocumentAsync"
                        OnToggleEndpoint="@State.ToggleEndpoint"
                        OnSelectOperation="@State.SelectOperation" />
    </PreviewContent>
</RequestWorkspace>

@code {
    protected override void OnInitialized()
    {
        State.Changed += HandleStateChanged;
        State.ChangedAsync += HandleStateChangedAsync;
    }

    private async void HandleStateChanged()
    {
        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception exception)
        {
            await DispatchExceptionAsync(exception);
        }
    }

    private async Task HandleStateChangedAsync()
    {
        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception exception)
        {
            await DispatchExceptionAsync(exception);
        }
    }

    public void Dispose()
    {
        State.Changed -= HandleStateChanged;
        State.ChangedAsync -= HandleStateChangedAsync;
    }
}
