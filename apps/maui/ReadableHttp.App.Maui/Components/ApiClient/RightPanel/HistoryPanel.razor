<section class="panel-content history-panel">
    <header class="panel-title">
        <span>History</span>
        <strong>@HistoryRecords.Count</strong>
    </header>
    <div class="history-list">
        @foreach (var record in HistoryRecords)
        {
            var expanded = ExpandedHistoryRecordId == record.Id;
            <article @key="record.Id" class="history-record">
                <button type="button" class="history-row" @onclick="() => OnToggleHistoryRecord.InvokeAsync(record.Id)">
                    <span class="method tiny @record.Method.ToLowerInvariant()">@record.Method</span>
                    <strong>@record.StatusText</strong>
                    <small>@record.StartedAt.ToLocalTime().ToString("HH:mm:ss")</small>
                    <em>@(expanded ? "▴" : "▾")</em>
                </button>
                <span class="history-url">@record.Url</span>
                @if (expanded)
                {
                    <dl class="history-detail">
                        <div><dt>Request</dt><dd>@record.Title</dd></div>
                        <div><dt>Trace</dt><dd>@TraceLabel(record)</dd></div>
                        <div><dt>Response</dt><dd>@ResponseSummary(record)</dd></div>
                    </dl>
                    @if (!string.IsNullOrWhiteSpace(record.Exchange.Response?.BodyText))
                    {
                        <pre>@record.Exchange.Response.BodyText</pre>
                    }
                }
            </article>
        }
        @if (HistoryRecords.Count == 0)
        {
            <div class="empty-copy">No request history yet.</div>
        }
    </div>
</section>

@code {
    [Parameter] public IReadOnlyList<HistoryRecord> HistoryRecords { get; set; } = [];
    [Parameter] public string? ExpandedHistoryRecordId { get; set; }
    [Parameter] public EventCallback<string> OnToggleHistoryRecord { get; set; }

    private static string TraceLabel(HistoryRecord record)
    {
        return string.IsNullOrWhiteSpace(record.RequestId)
            ? "snapshot only"
            : $"{record.CollectionId ?? "collection"} / {record.RequestId}";
    }

    private static string ResponseSummary(HistoryRecord record)
    {
        var response = record.Exchange.Response;
        if (response is null)
        {
            return "no response";
        }

        var bodyLength = response.BodyText?.Length ?? 0;
        return $"{response.StatusCode} · {bodyLength} chars";
    }
}
