@using ReadableHttp.AI

<section class="panel-content ai-panel">
    <header class="panel-title">
        <span>AI Assistant</span>
        <strong>MAF</strong>
    </header>
    <div class="ai-context">
        <span>@Method</span>
        <strong>@Url</strong>
    </div>
    <div class="ai-quick-actions">
        <button type="button" @onclick='() => SendQuickPrompt("读取当前参数并给出优化建议")'>参数</button>
        <button type="button" @onclick='() => SendQuickPrompt("读取当前响应结果并解释")'>结果</button>
        <button type="button" @onclick='() => SendQuickPrompt("分析失败原因并给出调整参数建议")'>失败原因</button>
        <button type="button" @onclick='() => SendQuickPrompt("对比最近历史记录")'>历史对比</button>
    </div>
    <div class="chat-log">
        @foreach (var message in AiMessages)
        {
            <div @key="message" class="chat-message @message.Role">
                <strong>@message.Role</strong>
                <p>@message.Content</p>
            </div>
        }
        @foreach (var action in PendingAiActions)
        {
            <div @key="action.Id" class="ai-action-card">
                <header>
                    <strong>@action.Title</strong>
                    <span>@ActionSafetyLabel(action)</span>
                </header>
                <p>@action.Summary</p>
                @if (action.RequestPatch is not null)
                {
                    <ul>
                        @foreach (var change in ActionChanges(action.RequestPatch))
                        {
                            <li @key="change">@change</li>
                        }
                    </ul>
                }
                <footer>
                    <button class="accent-button" @onclick="() => OnApplyAiAction.InvokeAsync(action.Id)">应用</button>
                    <button type="button" @onclick="() => OnDismissAiAction.InvokeAsync(action.Id)">忽略</button>
                </footer>
            </div>
        }
    </div>
    <footer class="chat-input">
        <textarea value="@AiDraft" @onchange="HandleAiDraftChanged" placeholder="@T("askRequest")" />
        <button class="accent-button" @onclick="OnSendAiMessage">@T("send")</button>
    </footer>
</section>

@code {
    [Parameter] public string Method { get; set; } = "GET";
    [Parameter] public string Url { get; set; } = string.Empty;
    [Parameter] public Func<string, string> T { get; set; } = static key => key;
    [Parameter] public IReadOnlyList<AiChatMessage> AiMessages { get; set; } = [];
    [Parameter] public IReadOnlyList<ReadableAiAction> PendingAiActions { get; set; } = [];
    [Parameter] public string AiDraft { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> AiDraftChanged { get; set; }
    [Parameter] public EventCallback OnSendAiMessage { get; set; }
    [Parameter] public EventCallback<string> OnSendAiQuickPrompt { get; set; }
    [Parameter] public EventCallback<string> OnApplyAiAction { get; set; }
    [Parameter] public EventCallback<string> OnDismissAiAction { get; set; }

    private static string ActionSafetyLabel(ReadableAiAction action)
    {
        return action.Confirmation.RequiresConfirmation
            ? action.Confirmation.Safety.ToString()
            : "ReadOnly";
    }

    private static IReadOnlyList<string> ActionChanges(ReadableAiRequestPatch patch)
    {
        var changes = new List<string>();
        if (!string.IsNullOrWhiteSpace(patch.Method))
        {
            changes.Add($"Method -> {patch.Method}");
        }

        if (!string.IsNullOrWhiteSpace(patch.Url))
        {
            changes.Add($"URL -> {patch.Url}");
        }

        changes.AddRange(patch.QueryChanges.Select(change => $"Query {change.Name} = {change.SuggestedValue}"));
        changes.AddRange(patch.HeaderChanges.Select(change => $"Header {change.Name} = {change.SuggestedValue}"));
        changes.AddRange(patch.FormChanges.Select(change => $"Form {change.Name} = {change.SuggestedValue}"));
        if (patch.BodyText is not null)
        {
            changes.Add($"Body -> {patch.BodyType ?? "Raw"}");
        }

        return changes;
    }

    private async Task SendQuickPrompt(string prompt)
    {
        await OnSendAiQuickPrompt.InvokeAsync(prompt);
    }

    private async Task HandleAiDraftChanged(ChangeEventArgs args)
    {
        await AiDraftChanged.InvokeAsync(Convert.ToString(args.Value) ?? string.Empty);
    }
}
