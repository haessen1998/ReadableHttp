<section class="main-stage" @onclick="CloseTabMenu">
    <nav class="request-tab-strip" aria-label="Open requests" @onclick="CloseTabMenu">
        @foreach (var tab in RequestTabs)
        {
            <div @key="tab.Id" class="tab-wrap">
                <button class="@OpenTabClass(tab)"
                        @onclick="() => SelectOpenTab(tab.Id)"
                        @oncontextmenu:preventDefault="true"
                        @oncontextmenu="() => ToggleTabMenu(tab.Id)">
                    <span class="tab-origin icon" title="@tab.Origin">@TabIcon(tab.Origin)</span>
                    <strong>@tab.Title</strong>
                    @if (tab.IsDirty)
                    {
                        <em>●</em>
                    }
                    <i @onclick:stopPropagation="true" @onclick="() => OnCloseOpenTab.InvokeAsync(tab.Id)">×</i>
                </button>
                @if (PendingCloseTabId == tab.Id)
                {
                    <div class="tab-confirm" @onclick:stopPropagation="true">
                        <span>@T("unsaved")</span>
                        <button @onclick="() => SaveAndCloseTab(tab.Id)">@T("save")</button>
                        <button @onclick="() => OnConfirmCloseOpenTab.InvokeAsync(tab.Id)">@T("discard")</button>
                        <button @onclick="OnCancelCloseOpenTab">@T("cancel")</button>
                    </div>
                }
                @if (contextMenuTabId == tab.Id)
                {
                    <div class="tab-menu" @onclick:stopPropagation="true">
                        <button @onclick="() => OnSaveOpenTab.InvokeAsync(tab.Id)">@T("save")</button>
                        <button @onclick="() => OnCloseOpenTab.InvokeAsync(tab.Id)">@T("close")</button>
                        <button @onclick="() => OnCloseOtherOpenTabs.InvokeAsync(tab.Id)">@T("closeOthers")</button>
                        <button @onclick="OnCloseAllOpenTabs">@T("closeAll")</button>
                    </div>
                }
            </div>
        }
        <button class="new-tab-button" title="New scratch request" @onclick="OnNewScratchRequest">+</button>
    </nav>

    @if (ActiveRequestOrigin is null)
    {
        <section class="blank-page"></section>
    }
    else if (IsRequestEditor)
    {
        <header class="request-toolbar">
            <div class="method-field @Method.ToLowerInvariant()">
                <select value="@Method" @onchange="HandleMethodChanged">
                    <option value="GET">GET</option>
                    <option value="POST">POST</option>
                    <option value="PUT">PUT</option>
                    <option value="PATCH">PATCH</option>
                    <option value="DELETE">DELETE</option>
                </select>
            </div>
            <div class="url-field">
                <input value="@Url" @onchange="HandleUrlChanged" />
            </div>
            <button class="send-button" @onclick="OnSend" disabled="@IsSending">@T("send")</button>
        </header>
    }

    @if (ActiveRequestOrigin is null)
    {
    }
    else if (ActiveRequestOrigin == RequestTabOrigin.Settings)
    {
        <SettingsPage SettingsDraft="@SettingsDraft"
                      T="@T"
                      ThemeModeChanged="@ThemeModeChanged"
                      LanguageChanged="@LanguageChanged"
                      FontSizeChanged="@FontSizeChanged"
                      ProxyModeChanged="@ProxyModeChanged"
                      CustomProxyUrlChanged="@CustomProxyUrlChanged"
                      CustomProxyUsernameChanged="@CustomProxyUsernameChanged"
                      CustomProxyPasswordChanged="@CustomProxyPasswordChanged"
                      DevToolsEnabledChanged="@DevToolsEnabledChanged"
                      OnSaveSettings="@OnSaveSettings" />
    }
    else if (ActiveRequestOrigin == RequestTabOrigin.About)
    {
        <section class="config-page about-page">
            <header>
                <span>@T("about")</span>
                <strong>@DocumentTitle</strong>
            </header>
            <section class="config-section">
                <h2>@DocumentTitle</h2>
                <p>@AboutDescription</p>
                <div class="config-grid">
                    @foreach (var stat in AboutStats)
                    {
                        <span @key="stat.Key">@stat.Key <strong>@stat.Value</strong></span>
                    }
                </div>
            </section>
        </section>
    }
    else if (ActiveRequestOrigin == RequestTabOrigin.Workspace)
    {
        <section class="config-page">
            <header>
                <span>@T("workspace")</span>
                <strong>@WorkspaceName</strong>
            </header>
            <section class="config-section">
                <h2>@T("scope")</h2>
                <label><span>@T("name")</span><input value="@WorkspaceName" @onchange="HandleWorkspaceNameChanged" /></label>
                <label><span>@T("type")</span><input value="@WorkspaceTypeLabel" readonly /></label>
                <label><span>@T("path")</span><input value="@WorkspacePath" readonly /></label>
                @if (WorkspaceTypeLabel == "Git")
                {
                    <label><span>Remote URL</span><input value="@WorkspaceRemoteUrl" @onchange="HandleWorkspaceRemoteUrlChanged" /></label>
                }
                <div class="config-grid">
                    <span>@T("collections") <strong>@CollectionCount</strong></span>
                    <span>@T("specifications") <strong>@SpecificationCount</strong></span>
                </div>
            </section>
            <section class="config-section">
                <h2>@T("workspaceVariables")</h2>
                @RenderVariableEditor("workspace", WorkspaceVariables)
            </section>
            <section class="config-section">
                <div class="section-heading-row">
                    <h2>@T("environments")</h2>
                    <button type="button" class="mini-tool-button" @onclick="OnAddEnvironment">@T("newEnvironment")</button>
                </div>
                <div class="environment-list">
                    @foreach (var environment in Environments)
                    {
                        <article class="environment-editor" @key="environment.Id">
                            <div class="environment-editor-header">
                                <label class="field-line">
                                    <span>@T("name")</span>
                                    <input value="@environment.Name" @onchange='args => OnSetEnvironment.InvokeAsync(new EnvironmentChange(environment.Id, "name", Convert.ToString(args.Value)))' />
                                </label>
                                <button type="button" class="mini-danger-button" @onclick="() => OnRemoveEnvironment.InvokeAsync(environment.Id)">@T("delete")</button>
                            </div>
                            @RenderVariableEditor(EnvironmentScope(environment.Id), environment.Variables.ToList())
                        </article>
                    }
                    @if (Environments.Count == 0)
                    {
                        <div class="body-mode-note">@T("noEnvironment")</div>
                    }
                </div>
            </section>
            <footer class="settings-footer">
                <button class="save-button" @onclick="OnSaveWorkspaceConfig">@T("saveWorkspace")</button>
            </footer>
        </section>
    }
    else if (ActiveRequestOrigin == RequestTabOrigin.CollectionConfig)
    {
        <section class="config-page">
            <header>
                <span>@T("collection")</span>
                <strong>@CollectionName</strong>
            </header>
            <section class="config-section">
                <h2>@T("scope")</h2>
                <label><span>@T("name")</span><input value="@CollectionName" @onchange="HandleCollectionNameChanged" /></label>
                <label><span>@T("requestDirectory")</span><input value="@CollectionRequestDirectory" @onchange="HandleCollectionRequestDirectoryChanged" /></label>
                <div class="config-grid">
                    <span>@T("source") <strong>@CollectionSource</strong></span>
                    <span>@T("requests") <strong>@CollectionRequestCount</strong></span>
                </div>
            </section>
            <section class="config-section">
                <h2>@T("environment")</h2>
                @RenderVariableEditor("collection", CollectionVariables)
            </section>
            <footer class="settings-footer">
                <button class="save-button" @onclick="OnSaveCollectionConfig">@T("saveCollection")</button>
            </footer>
        </section>
    }
    else if (ActiveRequestOrigin == RequestTabOrigin.SpecificationConfig)
    {
        <section class="config-page spec-config-page">
            <header>
                <span>@T("specification")</span>
                <strong>@SpecificationName</strong>
            </header>
            <section class="spec-config-summary">
                <span><small>@T("source")</small><strong>@SpecificationSourceLabel</strong></span>
                <span><small>@T("document")</small><strong>@SpecificationCacheStatus</strong></span>
                <span><small>@T("lastRefresh")</small><strong>@SpecificationLastRefreshedLabel</strong></span>
            </section>
            <section class="config-section spec-config-section">
                <h2>@T("source")</h2>
                <div class="config-field">
                    <span>@T("name")</span>
                    <input value="@SpecificationName" @onchange="HandleSpecificationNameChanged" />
                </div>
                <div class="config-field">
                    <span>@T("type")</span>
                    <input value="@SpecificationSourceLabel" readonly />
                </div>
                @if (SpecificationSourceLabel == "RemoteEndpoint")
                {
                    <div class="config-field">
                        <span>Endpoint</span>
                        <input value="@SpecificationEndpoint" @onchange="HandleSpecificationEndpointChanged" />
                    </div>
                    <div class="config-field">
                        <span>@T("cachedDocument")</span>
                        <input value="@SpecificationCachePath" readonly />
                    </div>
                }
                else
                {
                    <div class="config-field">
                        <span>@T("path")</span>
                        <input value="@SpecificationPath" readonly />
                    </div>
                }
            </section>
            <footer class="settings-footer">
                <button class="save-button" @onclick="OnSaveSpecificationConfig">@T("saveSpecification")</button>
                @if (SpecificationSourceLabel == "RemoteEndpoint")
                {
                    <button class="save-as-button" @onclick="OnRefreshSpecificationConfig">@T("refresh")</button>
                }
            </footer>
        </section>
    }
    else if (ActiveRequestOrigin == RequestTabOrigin.SpecificationDocument && ViewMode == "raw")
    {
        <pre class="raw-view">@RawContent</pre>
    }
    else if (ActiveRequestOrigin == RequestTabOrigin.SpecificationDocument)
    {
        <section class="spec-document-page">
            @PreviewContent
        </section>
    }
    else if (ViewMode == "raw")
    {
        <pre class="raw-view">@RawContent</pre>
    }
    else if (ViewMode == "preview")
    {
        @PreviewContent
    }
    else
    {
        <section class="request-canvas">
            <div class="@SplitEditorClass">
                @if (ResponseTab != "Full")
                {
                <section class="editor-pane request-pane">
                    <nav class="editor-tabs" aria-label="Request editor tabs">
                        <button class="@RequestTabClass("Info")" @onclick='() => OnSetRequestTab.InvokeAsync("Info")'>@T("requestInfo")</button>
                        <button class="@RequestTabClass("Params")" @onclick='() => OnSetRequestTab.InvokeAsync("Params")'>Params <span>@RequestQuery.Count</span></button>
                        <button class="@RequestTabClass("Body")" @onclick='() => OnSetRequestTab.InvokeAsync("Body")'>Body</button>
                        <button class="@RequestTabClass("Headers")" @onclick='() => OnSetRequestTab.InvokeAsync("Headers")'>Headers <span>@RequestHeaders.Count</span></button>
                        <button class="@RequestTabClass("Auth")" @onclick='() => OnSetRequestTab.InvokeAsync("Auth")'>Auth</button>
                        <button class="@RequestTabClass("Vars")" @onclick='() => OnSetRequestTab.InvokeAsync("Vars")'>Vars</button>
                        <button class="@RequestTabClass("Script")" @onclick='() => OnSetRequestTab.InvokeAsync("Script")'>Script</button>
                        <button class="@RequestTabClass("Assert")" @onclick='() => OnSetRequestTab.InvokeAsync("Assert")'>Assert</button>
                        <button class="tab-more" type="button" title="@T("more")">@Icon("chevron")</button>
                        <span class="tab-spacer"></span>
                        @if (RequestTab == "Body")
                        {
                            <label class="body-type-picker">
                                <span>@BodyTypeLabel(BodyType)</span>
                                <select value="@BodyType" @onchange="HandleBodyTypeChanged" title="Body type">
                                    <option value="@ReadableBodyType.MultipartFormData">Multipart Form</option>
                                    <option value="@ReadableBodyType.FormUrlEncoded">Form URL Encoded</option>
                                    <option value="@ReadableBodyType.Json">JSON</option>
                                    <option value="@ReadableBodyType.Xml">XML</option>
                                    <option value="@ReadableBodyType.Raw">TEXT</option>
                                    <option value="@ReadableBodyType.Graphql">GraphQL</option>
                                    <option value="@ReadableBodyType.Html">HTML</option>
                                    <option value="@ReadableBodyType.Javascript">JavaScript</option>
                                    <option value="@ReadableBodyType.BinaryFile">File / Binary</option>
                                    <option value="@ReadableBodyType.None">No Body</option>
                                </select>
                            </label>
                        }
                    </nav>
                    <div class="request-config">
                        @if (RequestTab == "Info")
                        {
                            <div class="request-form request-info-form">
                                <label class="field-line"><span>@T("name")</span><input value="@RequestName" @onchange="HandleRequestNameChanged" /></label>
                                <label class="field-line">
                                    <span>@T("environment")</span>
                                    <select value="@SelectedEnvironmentId" @onchange="HandleSelectedEnvironmentChanged">
                                        <option value="">@T("noEnvironment")</option>
                                        @foreach (var environment in Environments)
                                        {
                                            <option @key="environment.Id" value="@environment.Id">@environment.Name</option>
                                        }
                                    </select>
                                </label>
                                <label class="field-line">
                                    <span>@T("currentCollection")</span>
                                    <select value="@ActiveRequestCollectionId" @onchange="HandleMoveActiveRequestToCollection">
                                        <option value="">@ActiveRequestCollectionName</option>
                                        @foreach (var collection in RequestCollectionOptions)
                                        {
                                            <option @key="collection.Id" value="@collection.Id">@collection.Name</option>
                                        }
                                    </select>
                                </label>
                                <div class="request-info-actions">
                                    <button type="button" class="save-button" @onclick="OnSaveRequest">@T("save")</button>
                                    <button type="button" class="save-as-button" @onclick="OnSaveRequestAsNew">@T("saveAs")</button>
                                </div>
                            </div>
                        }
                        else if (RequestTab == "Params")
                        {
                            <div class="request-form">
                                @RenderNameValueEditor("query", RequestQuery)
                            </div>
                        }
                        else if (RequestTab == "Headers")
                        {
                            <div class="request-form">
                                @RenderNameValueEditor("headers", RequestHeaders)
                            </div>
                        }
                        else if (RequestTab == "Body")
                        {
                            <div class="request-form">
                                <div class="body-settings">
                                    <label>
                                        <span>Content-Type</span>
                                        <input value="@BodyContentType" @onchange="HandleBodyContentTypeChanged" />
                                    </label>
                                    <button type="button" class="mini-tool-button" @onclick="OnFormatBody"><span class="fluent-icon">@Icon("format")</span><span>@T("format")</span></button>
                                </div>
                                @if (BodyType == ReadableBodyType.FormUrlEncoded.ToString())
                                {
                                    @RenderNameValueEditor("form", RequestForm)
                                }
                                else if (BodyType == ReadableBodyType.MultipartFormData.ToString())
                                {
                                    @RenderNameValueEditor("form", RequestForm)
                                }
                                else if (BodyType == ReadableBodyType.BinaryFile.ToString())
                                {
                                    <div class="body-mode-note">File / Binary body will use the file path stored on the request body.</div>
                                }
                                else if (BodyType == ReadableBodyType.None.ToString())
                                {
                                    <div class="body-mode-note">This request will be sent without a body.</div>
                                }
                            </div>
                        }
                        else if (RequestTab == "Auth")
                        {
                            @RenderAuthEditor()
                        }
                        else if (RequestTab == "Vars")
                        {
                            <div class="request-form vars-grid">
                                <section>
                                    <div class="section-heading-row"><h2>@T("workspaceVariables")</h2></div>
                                    @RenderVariableEditor("workspace", WorkspaceVariables)
                                </section>
                                <section>
                                    <div class="section-heading-row"><h2>@T("collection")</h2></div>
                                    @RenderVariableEditor("collection", CollectionVariables)
                                </section>
                            </div>
                        }
                        else if (RequestTab == "Script")
                        {
                            <div class="script-grid">
                                <label class="script-editor">
                                    <span>Pre-request</span>
                                    <textarea value="@PreRequestScript" @onchange="HandlePreRequestScriptChanged" spellcheck="false"></textarea>
                                </label>
                                <label class="script-editor">
                                    <span>Test</span>
                                    <textarea value="@TestScript" @onchange="HandleTestScriptChanged" spellcheck="false"></textarea>
                                </label>
                            </div>
                        }
                        else if (RequestTab == "Assert")
                        {
                            <label class="script-editor assert-editor">
                                <span>Assertions</span>
                                <textarea value="@AssertText" @onchange="HandleAssertTextChanged" spellcheck="false" placeholder="status == 200&#10;json.ok == true"></textarea>
                            </label>
                        }
                    </div>
                    @if (RequestTab == "Body"
                        && BodyType != ReadableBodyType.FormUrlEncoded.ToString()
                        && BodyType != ReadableBodyType.MultipartFormData.ToString()
                        && BodyType != ReadableBodyType.BinaryFile.ToString()
                        && BodyType != ReadableBodyType.None.ToString())
                    {
                        <textarea class="request-body-textarea" value="@BodyText" @onchange="HandleBodyChanged" spellcheck="false"></textarea>
                    }
                </section>
                <div class="request-split-resizer" role="separator" tabindex="0" title="Resize request and response"></div>
                }
                <section class="editor-pane response-pane">
                    <div class="pane-header">
                        <div class="response-crumbs">
                            <button class="@ResponseTabClass("Response")" @onclick='() => OnSetResponseTab.InvokeAsync("Response")'>Response</button>
                            <button class="@ResponseTabClass("Request")" @onclick='() => OnSetResponseTab.InvokeAsync("Request")'>Request</button>
                            <button class="@ResponseTabClass("Full")" @onclick='() => OnSetResponseTab.InvokeAsync("Full")'>Full</button>
                            @if (ResponseTab != "Request")
                            {
                                <span>·</span>
                                <button @onclick='() => OnSelectResponseNode.InvokeAsync(new ResponseNodeSelectedEventArgs("root"))'>response</button>
                            }
                            @foreach (var crumb in ResponseBreadcrumbs())
                            {
                                <span>›</span>
                                <button @key="crumb.Path" @onclick="() => SelectResponseBreadcrumb(crumb.Path)">@crumb.Label</button>
                            }
                        </div>
                        <div class="response-meta-line">
                            <span class="@StatusClass">@StatusText</span>
                            <span>@(ResponseText.Length == 0 ? "0 B" : $"{ResponseText.Length} B")</span>
                            <button type="button" class="@ResponseWrapButtonClass" title="@T("wrapResponse")" @onclick="ToggleResponseWrap">↵</button>
                            <button type="button" class="pane-tool-button copy-response-button" title="@T("copy")" @onclick="OnCopySelectedResponse"><span class="fluent-icon">@Icon("copy")</span></button>
                        </div>
                    </div>
                    @if (ResponseTab == "Response" || ResponseTab == "Full")
                    {
                    <div class="response-pipeline">
                        <div class="pipeline-heading compact">
                            <span>HttpClient Pipeline</span>
                            <strong>@PipelineTotalLabel</strong>
                        </div>
                        @if (PipelinePhases.Count == 0)
                        {
                            <div class="pipeline-empty">Send a request to capture stage timings.</div>
                        }
                        else
                        {
                            <div class="pipeline-strip">
                                @foreach (var phase in PipelinePhases)
                                {
                                    <span @key="phase" style="width:@phase.Width%; background:@phase.Color" title="@($"{phase.Label} · {phase.Duration}")"></span>
                                }
                            </div>
                            <div class="pipeline-legend">
                                @foreach (var phase in PipelinePhases)
                                {
                                    <span @key="phase"><i style="background:@phase.Color"></i>@phase.Label <em>@phase.Duration</em></span>
                                }
                            </div>
                        }
                    </div>
                    }
                    @if (ResponseTab == "Request")
                    {
                        <div class="request-preview">
                            <pre>@RequestPreviewText</pre>
                        </div>
                    }
                    else if (string.IsNullOrWhiteSpace(ResponseText))
                    {
                        <div class="response-empty">
                            <strong>@StatusText</strong>
                            <span>@Method @Url</span>
                        </div>
                    }
                    else
                    {
                        <div class="@ResponseBodyClass">
                            @if (ResponseNodeKeys.Count > 0)
                            {
                                <div class="json-node-bar">
                                    <button class="@ResponseNodeClass("root")" @onclick='() => OnSelectResponseNode.InvokeAsync(new ResponseNodeSelectedEventArgs("root"))'>response</button>
                                    @foreach (var node in ResponseNodeKeys)
                                    {
                                        <button @key="node" class="@ResponseNodeClass(AbsoluteResponseNodePath(node))" @onclick="() => OnSelectResponseNode.InvokeAsync(new ResponseNodeSelectedEventArgs(AbsoluteResponseNodePath(node)))">@node</button>
                                    }
                                </div>
                            }
                            <pre>@SelectedResponseText</pre>
                        </div>
                    }
                </section>
            </div>
        </section>
    }
</section>

@code {
    private string? contextMenuTabId;
    private bool wrapResponseText;

    [Parameter] public string Method { get; set; } = "GET";
    [Parameter] public EventCallback<string> MethodChanged { get; set; }
    [Parameter] public string Url { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> UrlChanged { get; set; }
    [Parameter] public string BodyText { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> BodyTextChanged { get; set; }
    [Parameter] public string PreRequestScript { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> PreRequestScriptChanged { get; set; }
    [Parameter] public string TestScript { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> TestScriptChanged { get; set; }
    [Parameter] public string AssertText { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> AssertTextChanged { get; set; }
    [Parameter] public EventCallback OnFormatBody { get; set; }
    [Parameter] public string BodyType { get; set; } = ReadableBodyType.None.ToString();
    [Parameter] public EventCallback<string> BodyTypeChanged { get; set; }
    [Parameter] public string BodyContentType { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> BodyContentTypeChanged { get; set; }
    [Parameter] public IReadOnlyList<ReadableNameValue> RequestQuery { get; set; } = [];
    [Parameter] public IReadOnlyList<ReadableNameValue> RequestHeaders { get; set; } = [];
    [Parameter] public IReadOnlyList<ReadableNameValue> RequestForm { get; set; } = [];
    [Parameter] public ReadableAuth? RequestAuth { get; set; }
    [Parameter] public EventCallback<string> OnAddNameValue { get; set; }
    [Parameter] public EventCallback<EditableNameValueChange> OnSetNameValue { get; set; }
    [Parameter] public EventCallback<EditableNameValueChange> OnRemoveNameValue { get; set; }
    [Parameter] public EventCallback<AuthChange> OnSetAuth { get; set; }
    [Parameter] public bool IsSending { get; set; }
    [Parameter] public string ViewMode { get; set; } = "request";
    [Parameter] public string RawContent { get; set; } = string.Empty;
    [Parameter] public RenderFragment? PreviewContent { get; set; }
    [Parameter] public string RequestTab { get; set; } = "Params";
    [Parameter] public string ResponseTab { get; set; } = "Response";
    [Parameter] public string RequestName { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> RequestNameChanged { get; set; }
    [Parameter] public string WorkspaceName { get; set; } = "scratch";
    [Parameter] public EventCallback<string> WorkspaceNameChanged { get; set; }
    [Parameter] public string WorkspaceTypeLabel { get; set; } = "Local";
    [Parameter] public IReadOnlyList<KeyValuePair<string, ReadableVariable>> WorkspaceVariables { get; set; } = [];
    [Parameter] public IReadOnlyList<KeyValuePair<string, ReadableVariable>> CollectionVariables { get; set; } = [];
    [Parameter] public IReadOnlyList<ReadableEnvironment> Environments { get; set; } = [];
    [Parameter] public IReadOnlyList<ReadableCollection> RequestCollectionOptions { get; set; } = [];
    [Parameter] public string ActiveRequestCollectionId { get; set; } = string.Empty;
    [Parameter] public string ActiveRequestCollectionName { get; set; } = string.Empty;
    [Parameter] public string SelectedEnvironmentId { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SelectedEnvironmentIdChanged { get; set; }
    [Parameter] public EventCallback OnAddEnvironment { get; set; }
    [Parameter] public EventCallback<EnvironmentChange> OnSetEnvironment { get; set; }
    [Parameter] public EventCallback<string> OnRemoveEnvironment { get; set; }
    [Parameter] public EventCallback<string> OnAddVariable { get; set; }
    [Parameter] public EventCallback<VariableChange> OnSetVariable { get; set; }
    [Parameter] public EventCallback<VariableChange> OnRemoveVariable { get; set; }
    [Parameter] public string WorkspaceRemoteUrl { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> WorkspaceRemoteUrlChanged { get; set; }
    [Parameter] public string WorkspacePath { get; set; } = string.Empty;
    [Parameter] public int CollectionCount { get; set; }
    [Parameter] public int SpecificationCount { get; set; }
    [Parameter] public string CollectionName { get; set; } = "Collection";
    [Parameter] public EventCallback<string> CollectionNameChanged { get; set; }
    [Parameter] public string CollectionSource { get; set; } = "Local";
    [Parameter] public string CollectionRequestDirectory { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> CollectionRequestDirectoryChanged { get; set; }
    [Parameter] public int CollectionRequestCount { get; set; }
    [Parameter] public string SpecificationName { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SpecificationNameChanged { get; set; }
    [Parameter] public string SpecificationSourceLabel { get; set; } = string.Empty;
    [Parameter] public string SpecificationEndpoint { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SpecificationEndpointChanged { get; set; }
    [Parameter] public string SpecificationPath { get; set; } = string.Empty;
    [Parameter] public string SpecificationCachePath { get; set; } = string.Empty;
    [Parameter] public string SpecificationCacheStatus { get; set; } = "Not cached";
    [Parameter] public string SpecificationLastRefreshedLabel { get; set; } = "Never";
    [Parameter] public string ActiveSource { get; set; } = "Request";
    [Parameter] public string DocumentTitle { get; set; } = string.Empty;
