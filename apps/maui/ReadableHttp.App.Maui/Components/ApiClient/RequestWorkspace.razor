    }

    private void ToggleTabMenu(string tabId)
    {
        contextMenuTabId = contextMenuTabId == tabId ? null : tabId;
    }

    private void CloseTabMenu()
    {
        contextMenuTabId = null;
    }

    private async Task SaveAndCloseTab(string tabId)
    {
        await OnSaveOpenTab.InvokeAsync(tabId);
        await OnConfirmCloseOpenTab.InvokeAsync(tabId);
    }

