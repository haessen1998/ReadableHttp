    private RenderFragment RenderNameValueEditor(string kind, IReadOnlyList<ReadableNameValue> items) => @<div class="name-value-editor">
        <div class="name-value-actions">
            <button type="button" @onclick="() => OnAddNameValue.InvokeAsync(kind)">Add</button>
        </div>
        <table class="param-table editable">
            <thead>
                <tr><th></th><th>Name</th><th>Value</th><th></th></tr>
            </thead>
            <tbody>
                @for (var index = 0; index < items.Count; index++)
                {
                    var item = items[index];
                    var rowIndex = index;
                    <tr @key="item">
                        <td>
                            <input type="checkbox"
                                   checked="@item.Enabled"
                                   @onchange='args => OnSetNameValue.InvokeAsync(new EditableNameValueChange(kind, rowIndex, "enabled", Convert.ToString(args.Value)))' />
                        </td>
                        <td>
                            <input value="@item.Name"
                                   @onchange='args => OnSetNameValue.InvokeAsync(new EditableNameValueChange(kind, rowIndex, "name", Convert.ToString(args.Value)))' />
                        </td>
                        <td>
                            <input value="@item.Value"
                                   @onchange='args => OnSetNameValue.InvokeAsync(new EditableNameValueChange(kind, rowIndex, "value", Convert.ToString(args.Value)))' />
                        </td>
                        <td>
                            <button type="button" title="Remove" @onclick='() => OnRemoveNameValue.InvokeAsync(new EditableNameValueChange(kind, rowIndex, "remove", null))'>×</button>
                        </td>
                    </tr>
                }
                @if (items.Count == 0)
                {
                    <tr><td colspan="4" class="empty-row">No values</td></tr>
                }
            </tbody>
        </table>
    </div>;

    private RenderFragment RenderVariableEditor(string scope, IReadOnlyList<KeyValuePair<string, ReadableVariable>> items) => @<div class="name-value-editor">
        <div class="name-value-actions">
            <button type="button" @onclick="() => OnAddVariable.InvokeAsync(scope)">Add</button>
        </div>
        <table class="param-table editable">
            <thead>
                <tr><th></th><th>Name</th><th>Value</th><th></th></tr>
            </thead>
            <tbody>
                @for (var index = 0; index < items.Count; index++)
                {
                    var entry = items[index];
                    var rowIndex = index;
                    <tr @key="entry.Key">
                        <td>
                            <input type="checkbox"
                                   checked="@entry.Value.Enabled"
                                   @onchange='args => OnSetVariable.InvokeAsync(new VariableChange(scope, rowIndex, "enabled", Convert.ToString(args.Value)))' />
                        </td>
                        <td>
                            <input value="@entry.Key"
                                   @onchange='args => OnSetVariable.InvokeAsync(new VariableChange(scope, rowIndex, "name", Convert.ToString(args.Value)))' />
                        </td>
                        <td>
                            <input value="@VariableValue(entry.Value)"
                                   @onchange='args => OnSetVariable.InvokeAsync(new VariableChange(scope, rowIndex, "value", Convert.ToString(args.Value)))' />
                        </td>
                        <td>
                            <button type="button" title="Remove" @onclick='() => OnRemoveVariable.InvokeAsync(new VariableChange(scope, rowIndex, "remove", null))'>×</button>
                        </td>
                    </tr>
                }
                @if (items.Count == 0)
                {
                    <tr><td colspan="4" class="empty-row">No variables</td></tr>
                }
            </tbody>
        </table>
    </div>;

    private RenderFragment RenderAuthEditor() => @<div class="auth-editor">
        <label class="field-line">
            <span>Type</span>
            <select value="@AuthTypeValue" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("type", Convert.ToString(args.Value)))'>
                <option value="@ReadableAuthType.None">No Auth</option>
                <option value="@ReadableAuthType.Inherit">Inherit</option>
                <option value="@ReadableAuthType.Basic">Basic</option>
                <option value="@ReadableAuthType.Bearer">Bearer</option>
                <option value="@ReadableAuthType.OAuth1">OAuth 1.0</option>
                <option value="@ReadableAuthType.OAuth2">OAuth 2.0</option>
            </select>
        </label>

        @if (RequestAuth?.Type == ReadableAuthType.Basic)
        {
            <div class="auth-grid">
                <label class="field-line"><span>Username</span><input value="@RequestAuth.Username" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("username", Convert.ToString(args.Value)))' /></label>
                <label class="field-line"><span>Password</span><input type="password" value="@RequestAuth.Password" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("password", Convert.ToString(args.Value)))' /></label>
            </div>
        }
        else if (RequestAuth?.Type == ReadableAuthType.Bearer)
        {
            <label class="field-line"><span>Token</span><input value="@RequestAuth.Token" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("token", Convert.ToString(args.Value)))' /></label>
        }
        else if (RequestAuth?.Type == ReadableAuthType.OAuth1)
        {
            var oauth1 = RequestAuth.OAuth1 ?? new ReadableOAuth1Options();
            <div class="auth-grid">
                <label class="field-line"><span>Consumer Key</span><input value="@oauth1.ConsumerKey" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("oauth1.consumerKey", Convert.ToString(args.Value)))' /></label>
                <label class="field-line"><span>Consumer Secret</span><input type="password" value="@oauth1.ConsumerSecret" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("oauth1.consumerSecret", Convert.ToString(args.Value)))' /></label>
                <label class="field-line"><span>Token</span><input value="@oauth1.Token" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("oauth1.token", Convert.ToString(args.Value)))' /></label>
                <label class="field-line"><span>Token Secret</span><input type="password" value="@oauth1.TokenSecret" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("oauth1.tokenSecret", Convert.ToString(args.Value)))' /></label>
                <label class="field-line"><span>Signature</span><select value="@oauth1.SignatureMethod" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("oauth1.signatureMethod", Convert.ToString(args.Value)))'><option value="@ReadableOAuth1SignatureMethod.HmacSha1">HMAC-SHA1</option><option value="@ReadableOAuth1SignatureMethod.PlainText">PLAINTEXT</option><option value="@ReadableOAuth1SignatureMethod.RsaSha1">RSA-SHA1</option></select></label>
                <label class="field-line"><span>Add To</span><select value="@oauth1.Placement" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("oauth1.placement", Convert.ToString(args.Value)))'><option value="@ReadableTokenPlacement.Header">Header</option><option value="@ReadableTokenPlacement.Query">Query</option></select></label>
            </div>
        }
        else if (RequestAuth?.Type == ReadableAuthType.OAuth2)
        {
            var oauth2 = RequestAuth.OAuth2 ?? new ReadableOAuth2Options();
            <div class="auth-grid">
                <label class="field-line"><span>Grant Type</span><select value="@oauth2.GrantType" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("oauth2.grantType", Convert.ToString(args.Value)))'><option value="@ReadableOAuth2GrantType.AuthorizationCode">Authorization Code</option><option value="@ReadableOAuth2GrantType.ClientCredentials">Client Credentials</option><option value="@ReadableOAuth2GrantType.PasswordCredentials">Password Credentials</option><option value="@ReadableOAuth2GrantType.RefreshToken">Refresh Token</option><option value="@ReadableOAuth2GrantType.Implicit">Implicit</option></select></label>
                <label class="field-line"><span>Token URL</span><input value="@oauth2.TokenUrl" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("oauth2.tokenUrl", Convert.ToString(args.Value)))' /></label>
                <label class="field-line"><span>Authorization URL</span><input value="@oauth2.AuthorizationUrl" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("oauth2.authorizationUrl", Convert.ToString(args.Value)))' /></label>
                <label class="field-line"><span>Client ID</span><input value="@oauth2.ClientId" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("oauth2.clientId", Convert.ToString(args.Value)))' /></label>
                <label class="field-line"><span>Client Secret</span><input type="password" value="@oauth2.ClientSecret" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("oauth2.clientSecret", Convert.ToString(args.Value)))' /></label>
                <label class="field-line"><span>Scope</span><input value="@string.Join(' ', oauth2.Scopes)" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("oauth2.scope", Convert.ToString(args.Value)))' /></label>
                <label class="field-line"><span>Token Source</span><select value="@oauth2.TokenSource" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("oauth2.tokenSource", Convert.ToString(args.Value)))'><option value="@ReadableOAuth2TokenSource.AccessToken">Access Token</option><option value="@ReadableOAuth2TokenSource.IdToken">ID Token</option></select></label>
                <label class="field-line"><span>Token ID</span><input value="@oauth2.TokenId" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("oauth2.tokenId", Convert.ToString(args.Value)))' /></label>
                <label class="field-line"><span>Add To</span><select value="@oauth2.TokenPlacement" @onchange='args => OnSetAuth.InvokeAsync(new AuthChange("oauth2.placement", Convert.ToString(args.Value)))'><option value="@ReadableTokenPlacement.Header">Header</option><option value="@ReadableTokenPlacement.Query">Query</option><option value="@ReadableTokenPlacement.RequestBody">Body</option></select></label>
            </div>
        }
    </div>;

    private static string VariableValue(ReadableVariable variable)
    {
