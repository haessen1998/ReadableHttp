    private string ResponseNodeClass(string path) => string.Equals(NormalizeResponsePath(ResponseNodePath), NormalizeResponsePath(path), StringComparison.Ordinal)
        ? "active"
        : string.Empty;

    private IReadOnlyList<(string Label, string Path)> ResponseBreadcrumbs()
    {
        var responsePath = NormalizeResponsePath(ResponseNodePath);
        if (responsePath == "root")
        {
            return [];
        }

        var crumbs = new List<(string Label, string Path)>();
        var path = string.Empty;
        foreach (var segment in responsePath.Split('.', StringSplitOptions.RemoveEmptyEntries))
        {
            path = string.IsNullOrWhiteSpace(path) ? segment : $"{path}.{segment}";
            crumbs.Add((segment, "/" + path));
        }

        return crumbs;
    }

    private async Task SelectResponseBreadcrumb(string path)
    {
        await OnSelectResponseNode.InvokeAsync(new ResponseNodeSelectedEventArgs(path));
    }

    private string AbsoluteResponseNodePath(string node)
    {
        var responsePath = NormalizeResponsePath(ResponseNodePath);
        return responsePath == "root" ? node : "/" + responsePath + "." + node;
    }

    private static string NormalizeResponsePath(string? path)
    {
        if (string.IsNullOrWhiteSpace(path) || path == "root")
        {
            return "root";
        }

        return path.StartsWith("/", StringComparison.Ordinal) ? path[1..] : path;
    }

    private static string TabIcon(RequestTabOrigin origin)
    {
        return origin switch
        {
            RequestTabOrigin.Workspace => "W",
            RequestTabOrigin.CollectionConfig => "C",
            RequestTabOrigin.Collection => "R",
            RequestTabOrigin.Specification => "R",
            RequestTabOrigin.SpecificationConfig => "S",
            RequestTabOrigin.SpecificationDocument => "D",
            RequestTabOrigin.About => "I",
            RequestTabOrigin.Settings => "⚙",
            _ => "+"
        };
    }
