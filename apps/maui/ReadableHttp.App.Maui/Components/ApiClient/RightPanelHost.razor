@using ReadableHttp.AI

<aside class="right-panel">
    <nav class="right-panel-tabs" aria-label="Right panel">
        <button class="@PanelButtonClass(RightPanelMode.Ai)" title="AI" @onclick="() => OnSelectMode.InvokeAsync(RightPanelMode.Ai)">AI</button>
        <button class="@PanelButtonClass(RightPanelMode.History)" title="History" @onclick="() => OnSelectMode.InvokeAsync(RightPanelMode.History)">Hist</button>
    </nav>

    @if (Mode == RightPanelMode.History)
    {
        <HistoryPanel HistoryRecords="@HistoryRecords"
                      ExpandedHistoryRecordId="@ExpandedHistoryRecordId"
                      OnToggleHistoryRecord="@OnToggleHistoryRecord" />
    }
    else
    {
        <AiPanel Method="@Method"
                 Url="@Url"
                 T="@T"
                 AiMessages="@AiMessages"
                 PendingAiActions="@PendingAiActions"
                 AiDraft="@AiDraft"
                 AiDraftChanged="@AiDraftChanged"
                 OnSendAiMessage="@OnSendAiMessage"
                 OnSendAiQuickPrompt="@OnSendAiQuickPrompt"
                 OnApplyAiAction="@OnApplyAiAction"
                 OnDismissAiAction="@OnDismissAiAction" />
    }
</aside>

@code {
    [Parameter] public RightPanelMode Mode { get; set; }
    [Parameter] public string Method { get; set; } = "GET";
    [Parameter] public string Url { get; set; } = string.Empty;
    [Parameter] public Func<string, string> T { get; set; } = static key => key;
    [Parameter] public IReadOnlyList<AiChatMessage> AiMessages { get; set; } = [];
    [Parameter] public IReadOnlyList<ReadableAiAction> PendingAiActions { get; set; } = [];
    [Parameter] public string AiDraft { get; set; } = string.Empty;
    [Parameter] public IReadOnlyList<HistoryRecord> HistoryRecords { get; set; } = [];
    [Parameter] public string? ExpandedHistoryRecordId { get; set; }
    [Parameter] public EventCallback<string> AiDraftChanged { get; set; }
    [Parameter] public EventCallback<RightPanelMode> OnSelectMode { get; set; }
    [Parameter] public EventCallback OnSendAiMessage { get; set; }
    [Parameter] public EventCallback<string> OnSendAiQuickPrompt { get; set; }
    [Parameter] public EventCallback<string> OnApplyAiAction { get; set; }
    [Parameter] public EventCallback<string> OnDismissAiAction { get; set; }
    [Parameter] public EventCallback<string> OnToggleHistoryRecord { get; set; }

    private string PanelButtonClass(RightPanelMode mode) => Mode == mode ? "active" : string.Empty;
}
