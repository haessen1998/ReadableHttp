            "folder" => "\uE8B7",
            "folderAdd" => "\uE8F4",
            "settings" => "\uE713",
            "save" => "\uE74E",
            "remove" => "\uE738",
            "git" => "\uE8EE",
            "collapse" => "\uE740",
            "document" => "\uE8A5",
            "cloud" => "\uE753",
            "text" => "\uE8D2",
            "size" => "\uE8B3",
