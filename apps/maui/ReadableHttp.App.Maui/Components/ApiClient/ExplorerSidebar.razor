@using ReadableHttp
@using System.Text.Json

<aside class="sidebar-panel" @onclick="CloseFlyouts">
    @if (HasOpenFlyout)
    {
        <button class="sidebar-flyout-backdrop" title="@T("close")" @onclick="CloseFlyouts"></button>
    }

    <header class="sidebar-brand">
        <div class="brand-button" title="@WorkspaceName">
            <span class="brand-mark" aria-hidden="true">
                <span class="brand-node"></span>
                <span class="brand-line long"></span>
                <span class="brand-node"></span>
                <span class="brand-line short"></span>
            </span>
            <span class="brand-copy">
                <strong>@(WorkspaceName ?? T("noWorkspace"))</strong>
                <small>@WorkspaceTypeLabel</small>
            </span>
        </div>
    </header>

    <section class="sidebar-search">
        <span>⌕</span>
        <input value="@searchText" @oninput="HandleSearchChanged" placeholder="@T("search")" />
        @if (!string.IsNullOrWhiteSpace(searchText))
        {
            <button title="@T("clearSearch")" @onclick="ClearSearch">×</button>
        }
    </section>

    <section class="nav-block">
        <div class="block-title">
            <button class="section-toggle" @onclick="OnToggleCollectionsSection">
                <span>@(ShowCollectionsSection ? "▾" : "▸")</span>
                <strong>@T("collections")</strong>
            </button>
            @if (HasActiveWorkspace)
            {
                <div class='@TitleActionsClass(MenuKey("collections", "actions"))' @onclick:stopPropagation="true">
                    <button title="@T("more")" @onclick='() => ToggleMore(MenuKey("collections", "actions"))'>···</button>
                    <div class="more-menu">
                        <button @onclick="OnNewCollection"><span class="fluent-icon">@Icon("add")</span><span>@T("newCollection")</span></button>
                        <button @onclick="OnLoadWorkspace"><span class="fluent-icon">@Icon("refresh")</span><span>@T("reloadCollections")</span></button>
                        <button @onclick="CollapseAllCollections"><span class="fluent-icon">@Icon("collapse")</span><span>@T("collapseAll")</span></button>
                        <button @onclick="OnShowCollectionsAbout"><span class="fluent-icon">@Icon("info")</span><span>@T("about")</span></button>
                        @RenderSortMenu("collections")
                    </div>
                </div>
            }
        </div>
        @if (ShowCollectionsSection && !HasVisibleCollectionContent)
        {
            <div class="empty-copy">@EmptyCollectionsText</div>
        }
        else if (ShowCollectionsSection)
        {
            <div class="nav-list">
                @if (RootCollection is not null)
                {
                    @RenderCollectionRequests(RootCollection, isRoot: true)
                }
                @foreach (var collection in SortedRootCollections)
                {
                    @RenderCollectionNode(collection)
                }
            </div>
        }
    </section>

    <section class="nav-block">
        <div class="block-title">
            <button class="section-toggle" @onclick="OnToggleSpecsSection">
                <span>@(ShowSpecsSection ? "▾" : "▸")</span>
                <strong>@T("specifications")</strong>
            </button>
            @if (HasActiveWorkspace)
            {
                <div class='@TitleActionsClass(MenuKey("add", "specification"))' @onclick:stopPropagation="true">
                    <button title="@T("more")" @onclick='() => ToggleMore(MenuKey("add", "specification"))'>···</button>
                    <div class="more-menu">
                        <button @onclick="OnPickTryFile"><span class="fluent-icon">@Icon("document")</span><span>@T("localFile")</span></button>
                        <button @onclick="OnNewRemoteSpecification"><span class="fluent-icon">@Icon("cloud")</span><span>@T("remoteEndpoint")</span></button>
                        <button @onclick="OnLoadWorkspace"><span class="fluent-icon">@Icon("refresh")</span><span>@T("reloadSpecifications")</span></button>
                        <button @onclick="OnShowSpecsAbout"><span class="fluent-icon">@Icon("info")</span><span>@T("about")</span></button>
                        @RenderSortMenu("specs")
                    </div>
                </div>
            }
        </div>
        @if (ShowSpecsSection && FilteredSpecifications.Count == 0)
        {
            <div class="empty-copy">@T("addSpecHint")</div>
        }
        else if (ShowSpecsSection)
        {
            <div class="nav-list">
                @foreach (var specification in SortedSpecifications)
                {
                    <div @key="specification" class="@SpecificationClass(specification)">
                        <button class="tree-main" @onclick="() => OnSelectSpecification.InvokeAsync(new SpecificationEventArgs(specification))">
                            <span class="item-main">@specification.Name</span>
                            <small>@SpecificationBadge(specification)</small>
                        </button>
                        <div class='@RowActionsClass(MenuKey("specification", specification.Id))' @onclick:stopPropagation="true">
                            @if (specification.SourceType == ReadableSpecificationSourceType.RemoteEndpoint)
                            {
                                <button title="@T("refreshRemoteDocument")" @onclick="() => OnRefreshSpecification.InvokeAsync(new SpecificationEventArgs(specification))">↻</button>
                            }
                            <button title="@T("more")" @onclick='() => ToggleMore(MenuKey("specification", specification.Id))'>···</button>
                            <div class="more-menu">
                                <button @onclick="() => OnOpenSpecificationConfig.InvokeAsync(new SpecificationEventArgs(specification))"><span class="fluent-icon">@Icon("settings")</span><span>@T("configure")</span></button>
                                @if (specification.SourceType == ReadableSpecificationSourceType.RemoteEndpoint)
                                {
                                    <button @onclick="() => OnRefreshSpecification.InvokeAsync(new SpecificationEventArgs(specification))"><span class="fluent-icon">@Icon("refresh")</span><span>@T("refreshRemoteDocument")</span></button>
                                }
                                <button @onclick="() => OnDuplicateSpecification.InvokeAsync(new SpecificationEventArgs(specification))"><span class="fluent-icon">@Icon("copy")</span><span>@T("duplicate")</span></button>
                                <button @onclick="() => OnOpenSpecificationInExplorer.InvokeAsync(new SpecificationEventArgs(specification))"><span class="fluent-icon">@Icon("folder")</span><span>@T("openInExplorer")</span></button>
                                <button class="danger-menu" @onclick="() => OnDeleteSpecification.InvokeAsync(new SpecificationEventArgs(specification))"><span class="fluent-icon">@Icon("delete")</span><span>@T("delete")</span></button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <footer class="sidebar-env">
        <div class="workspace-quick-host" @onclick:stopPropagation="true">
            <button class="workspace-quick-switch" title="@T("switchWorkspace")" @onclick="ToggleQuickSwitch">
                <span>@(WorkspaceName ?? WorkspaceLabel(WorkspacePath))</span>
                <small>@WorkspaceTypeLabel</small>
            </button>
            @if (quickSwitchOpen)
            {
                <div class="workspace-quick-menu">
                    <button class="quick-workspace-add" @onclick="OnNewWorkspace">
                        <span class="fluent-icon">@Icon("add")</span>
                        <span>@T("newWorkspace")</span>
                    </button>
                    <div class="quick-switch-separator"></div>
                    @foreach (var item in WorkspaceOptions)
                    {
                        var isActiveWorkspace = string.Equals(NormalizeWorkspacePath(WorkspacePath), item.Path, StringComparison.OrdinalIgnoreCase);
                        <div @key="item.Path" class="@WorkspaceQuickRowClass(item, isActiveWorkspace)">
                            <button class="quick-workspace-main" title="@WorkspaceMainTitle(item)" @onclick="() => SelectWorkspaceFromQuickSwitch(item)">
                                <span>@item.Label</span>
                                @if (!item.IsUsable)
                                {
                                    <small>@T("unavailable")</small>
                                }
                            </button>
                            <div class='@RowActionsClass(MenuKey("quick-workspace", item.Path), "quick-workspace-actions")' @onclick:stopPropagation="true">
                                <button title="@T("more")" @onclick='() => ToggleMore(MenuKey("quick-workspace", item.Path), keepQuickSwitch: true)'>···</button>
                                <div class="more-menu quick-workspace-more">
                                    @if (item.IsUsable)
                                    {
                                        <button @onclick="() => OnOpenWorkspaceConfig.InvokeAsync(new WorkspaceSelectedEventArgs(item.Path))"><span class="fluent-icon">@Icon("settings")</span><span>@T("configure")</span></button>
                                        <button @onclick="() => OnOpenWorkspaceInExplorer.InvokeAsync(new WorkspaceSelectedEventArgs(item.Path))"><span class="fluent-icon">@Icon("folder")</span><span>@T("openInExplorer")</span></button>
                                        @if (isActiveWorkspace)
                                        {
                                            <button @onclick="OnSaveWorkspace"><span class="fluent-icon">@Icon("save")</span><span>@T("save")</span></button>
                                            @if (IsGitWorkspace)
                                            {
                                                <button @onclick="OnGitStatus"><span class="fluent-icon">@Icon("git")</span><span>Git 状态</span></button>
                                                <button @onclick="OnGitPull"><span class="fluent-icon">@Icon("cloud")</span><span>拉取</span></button>
                                                <button @onclick="OnGitPush"><span class="fluent-icon">@Icon("cloud")</span><span>推送</span></button>
                                            }
                                        }
                                    }
                                    <button @onclick="() => OnRemoveWorkspaceOption.InvokeAsync(new WorkspaceSelectedEventArgs(item.Path))"><span class="fluent-icon">@Icon("remove")</span><span>@T("removeFromList")</span></button>
                                    @if (item.IsUsable)
                                    {
                                        @if (string.Equals(pendingDeleteWorkspacePath, item.Path, StringComparison.OrdinalIgnoreCase))
                                        {
                                            <button class="danger-menu" @onclick="() => ConfirmDeleteWorkspace(item.Path)"><span class="fluent-icon">@Icon("delete")</span><span>@T("confirmDeleteWorkspace")</span></button>
                                        }
                                        else
                                        {
                                            <button class="danger-menu" @onclick="() => pendingDeleteWorkspacePath = item.Path"><span class="fluent-icon">@Icon("delete")</span><span>@T("deleteWorkspaceFolder")</span></button>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
        <button class="footer-button settings-button" title="@T("settings")" @onclick="OnShowSettings">⚙</button>
    </footer>
</aside>

@code {
    private bool quickSwitchOpen;
    private string? openMenuKey;
    private string? pendingDeleteWorkspacePath;
    private string searchText = string.Empty;
    private string collectionsSort = "name";
    private string specsSort = "name";
    private readonly HashSet<string> expandedCollectionIds = [];
    private readonly Dictionary<string, string> requestSorts = [];

    [Parameter] public string WorkspacePath { get; set; } = string.Empty;
    [Parameter] public string WorkspaceStatus { get; set; } = string.Empty;
    [Parameter] public string? WorkspaceName { get; set; }
    [Parameter] public bool IsGitWorkspace { get; set; }
    [Parameter] public bool ShowWorkspaceSection { get; set; }
    [Parameter] public bool ShowCollectionsSection { get; set; }
    [Parameter] public bool ShowSpecsSection { get; set; }
    [Parameter] public bool ShowRecentSection { get; set; }
    [Parameter] public bool WorkspaceAutoInitialize { get; set; }
    [Parameter] public IReadOnlyList<WorkspaceOptionView> WorkspaceOptions { get; set; } = [];
    [Parameter] public Func<string, string> T { get; set; } = static key => key;
    [Parameter] public IReadOnlyList<ReadableCollection> Collections { get; set; } = [];
    [Parameter] public ReadableCollection? SelectedCollection { get; set; }
    [Parameter] public ReadableRequest? SelectedRequest { get; set; }
    [Parameter] public IReadOnlyList<ReadableSpecification> Specifications { get; set; } = [];
    [Parameter] public IReadOnlyList<string> SpecFiles { get; set; } = [];
    [Parameter] public string TryFilePath { get; set; } = string.Empty;
    [Parameter] public IReadOnlyList<string> RecentSessions { get; set; } = [];
    [Parameter] public string Method { get; set; } = "GET";
    [Parameter] public string DocumentTitle { get; set; } = string.Empty;

    [Parameter] public EventCallback OnNewScratchRequest { get; set; }
    [Parameter] public EventCallback OnShowSettings { get; set; }
    [Parameter] public EventCallback OnNewCollection { get; set; }
    [Parameter] public EventCallback OnPickWorkspace { get; set; }
    [Parameter] public EventCallback OnNewWorkspace { get; set; }
    [Parameter] public EventCallback OnNewRemoteWorkspace { get; set; }
    [Parameter] public EventCallback<bool> WorkspaceAutoInitializeChanged { get; set; }
    [Parameter] public EventCallback OnLoadWorkspace { get; set; }
    [Parameter] public EventCallback OnSaveWorkspace { get; set; }
    [Parameter] public EventCallback<WorkspaceSelectedEventArgs> OnOpenWorkspaceInExplorer { get; set; }
    [Parameter] public EventCallback<WorkspaceSelectedEventArgs> OnRemoveWorkspaceOption { get; set; }
    [Parameter] public EventCallback<WorkspaceSelectedEventArgs> OnDeleteWorkspaceFolder { get; set; }
    [Parameter] public EventCallback OnDeleteCollection { get; set; }
    [Parameter] public EventCallback OnDeleteRequest { get; set; }
    [Parameter] public EventCallback OnGitStatus { get; set; }
    [Parameter] public EventCallback OnGitPull { get; set; }
    [Parameter] public EventCallback OnGitPush { get; set; }
    [Parameter] public EventCallback<WorkspaceSelectedEventArgs> OnSelectWorkspace { get; set; }
    [Parameter] public EventCallback<WorkspaceSelectedEventArgs> OnOpenWorkspaceConfig { get; set; }
    [Parameter] public EventCallback OnToggleWorkspaceSection { get; set; }
    [Parameter] public EventCallback OnToggleCollectionsSection { get; set; }
    [Parameter] public EventCallback OnToggleSpecsSection { get; set; }
    [Parameter] public EventCallback OnToggleRecentSection { get; set; }
    [Parameter] public EventCallback OnShowCollectionsAbout { get; set; }
    [Parameter] public EventCallback OnShowSpecsAbout { get; set; }
    [Parameter] public EventCallback<CollectionEventArgs> OnSelectCollection { get; set; }
    [Parameter] public EventCallback<CollectionEventArgs> OnOpenCollectionConfig { get; set; }
    [Parameter] public EventCallback<RequestEventArgs> OnSelectRequest { get; set; }
    [Parameter] public EventCallback<CollectionEventArgs> OnNewSubCollection { get; set; }
    [Parameter] public EventCallback<CollectionEventArgs> OnNewRequestInCollection { get; set; }
    [Parameter] public EventCallback<CollectionEventArgs> OnDuplicateCollection { get; set; }
    [Parameter] public EventCallback<CollectionEventArgs> OnDeleteCollectionItem { get; set; }
    [Parameter] public EventCallback<CollectionEventArgs> OnOpenCollectionInExplorer { get; set; }
    [Parameter] public EventCallback<RequestEventArgs> OnDuplicateRequest { get; set; }
    [Parameter] public EventCallback<RequestMoveEventArgs> OnMoveRequest { get; set; }
    [Parameter] public EventCallback<RequestEventArgs> OnDeleteRequestItem { get; set; }
    [Parameter] public EventCallback<RequestEventArgs> OnOpenRequestDefault { get; set; }
    [Parameter] public EventCallback OnShowRequest { get; set; }
    [Parameter] public EventCallback OnPickTryFile { get; set; }
    [Parameter] public EventCallback OnNewRemoteSpecification { get; set; }
    [Parameter] public EventCallback OnLoadTryDocument { get; set; }
    [Parameter] public EventCallback<SpecSelectedEventArgs> OnSelectSpec { get; set; }
    [Parameter] public EventCallback<SpecificationEventArgs> OnSelectSpecification { get; set; }
    [Parameter] public EventCallback<SpecificationEventArgs> OnRefreshSpecification { get; set; }
    [Parameter] public EventCallback<SpecificationEventArgs> OnOpenSpecificationConfig { get; set; }
    [Parameter] public EventCallback<SpecificationEventArgs> OnOpenSpecificationInExplorer { get; set; }
    [Parameter] public EventCallback<SpecificationEventArgs> OnDuplicateSpecification { get; set; }
    [Parameter] public EventCallback<SpecificationEventArgs> OnDeleteSpecification { get; set; }
    [Parameter] public EventCallback OnShowRaw { get; set; }
    [Parameter] public EventCallback<SessionSelectedEventArgs> OnSelectSession { get; set; }

    private bool IsSearching => !string.IsNullOrWhiteSpace(searchText);

    private bool HasOpenFlyout => quickSwitchOpen || openMenuKey is not null;

    private bool HasActiveWorkspace => IsWorkspaceUsable(WorkspacePath);

    private string Query => searchText.Trim();

    private string WorkspaceTypeLabel => IsGitWorkspace ? T("gitWorkspace") : T("localWorkspace");

    private string EmptyCollectionsText => IsSearching ? T("noMatchingCollections") : T("createOrLoadCollection");

    private ReadableCollection? RootCollection => Collections.FirstOrDefault(IsRootCollection);

    private IReadOnlyList<ReadableCollection> RootLevelCollections => RootCollection is null
        ? Collections
        : Collections
            .Where(collection => !IsRootCollection(collection))
            .Concat(RootCollection.Children)
            .ToList();

    private IReadOnlyList<ReadableCollection> FilteredCollections => RootLevelCollections
        .Where(collection => CollectionMatches(collection))
        .ToList();

    private IReadOnlyList<ReadableCollection> SortedRootCollections => SortCollections(FilteredCollections).ToList();

    private bool HasVisibleCollectionContent =>
        FilteredCollections.Count > 0
        || (RootCollection is not null && FilteredRequests(RootCollection).Count > 0);

    private IReadOnlyList<ReadableSpecification> FilteredSpecifications => Specifications
        .Where(specification => Matches(specification.Name)
            || Matches(specification.Path)
            || Matches(specification.Remote?.Endpoint)
            || Matches(specification.SourceType.ToString()))
        .ToList();

    private IReadOnlyList<ReadableSpecification> SortedSpecifications => SortSpecifications(FilteredSpecifications).ToList();

    private IReadOnlyList<ReadableRequest> FilteredRequests(ReadableCollection collection)
    {
        return collection.Requests
            .Where(RequestMatches)
            .ToList();
    }

    private IReadOnlyList<ReadableRequest> SortedRequests(ReadableCollection collection)
    {
        var sort = requestSorts.TryGetValue(collection.Id, out var value) ? value : "name";
        return SortRequests(collection, FilteredRequests(collection), sort).ToList();
    }

    private IReadOnlyList<ReadableCollection> MoveTargetCollections(ReadableCollection source)
    {
        return EnumerateCollections(Collections)
            .Where(collection => !IsRootCollection(collection)
                && !string.Equals(collection.Id, source.Id, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private IEnumerable<ReadableCollection> SortCollections(IReadOnlyList<ReadableCollection> collections)
    {
        return collectionsSort switch
        {
            "size" => collections.OrderByDescending(collection => collection.Requests.Count).ThenBy(collection => collection.Name),
            "updated" => collections.OrderByDescending(CollectionUpdatedAt).ThenBy(collection => collection.Name),
            _ => collections.OrderBy(collection => collection.Name)
        };
    }

    private IEnumerable<ReadableSpecification> SortSpecifications(IReadOnlyList<ReadableSpecification> specifications)
    {
        return specsSort switch
        {
            "size" => specifications.OrderByDescending(SpecificationSize).ThenBy(specification => specification.Name),
            "updated" => specifications.OrderByDescending(SpecificationUpdatedAt).ThenBy(specification => specification.Name),
            _ => specifications.OrderBy(specification => specification.Name)
        };
    }

    private IEnumerable<ReadableRequest> SortRequests(ReadableCollection collection, IReadOnlyList<ReadableRequest> requests, string sort)
    {
        return sort switch
        {
            "size" => requests.OrderByDescending(request => RequestSize(collection, request)).ThenBy(request => request.Name),
            "updated" => requests.OrderByDescending(request => RequestUpdatedAt(collection, request)).ThenBy(request => request.Name),
            _ => requests.OrderBy(request => request.Name)
        };
    }

    private bool RequestMatches(ReadableRequest request)
    {
        return Matches(request.Name) || Matches(request.Method) || Matches(request.Url);
    }

    private bool CollectionMatches(ReadableCollection collection)
    {
        return Matches(collection.Name)
            || collection.Requests.Any(RequestMatches)
            || collection.Children.Any(CollectionMatches);
    }

    private IReadOnlyList<ReadableCollection> VisibleChildren(ReadableCollection collection)
    {
        return SortCollections(collection.Children
            .Where(CollectionMatches)
            .ToList())
            .ToList();
    }

    private RenderFragment RenderCollectionNode(ReadableCollection collection) => @<div @key="collection" class="collection-node">
        <div class="@CollectionClass(collection)">
            <button class="tree-main" @onclick="() => ToggleCollection(collection)">
                <span class="tree-caret">@(IsCollectionExpanded(collection) ? "▾" : "▸")</span>
                <span class="item-main">@collection.Name</span>
                <small>@CollectionBadge(collection)</small>
            </button>
            <div class='@RowActionsClass(MenuKey("collection", collection.Id))' @onclick:stopPropagation="true">
                <button title="@T("newRequest")" @onclick="() => OnNewRequestInCollection.InvokeAsync(new CollectionEventArgs(collection))">＋</button>
                <button title="@T("newSubCollection")" @onclick="() => AddSubCollection(collection)"><span class="fluent-icon">@Icon("folderAdd")</span></button>
                <button title="@T("more")" @onclick='() => ToggleMore(MenuKey("collection", collection.Id))'>···</button>
                <div class="more-menu">
                    <button @onclick="() => AddSubCollection(collection)"><span class="fluent-icon">@Icon("folderAdd")</span><span>@T("newSubCollection")</span></button>
                    <button @onclick="() => OnNewRequestInCollection.InvokeAsync(new CollectionEventArgs(collection))"><span class="fluent-icon">@Icon("add")</span><span>@T("newRequest")</span></button>
                    <button @onclick="() => OnOpenCollectionConfig.InvokeAsync(new CollectionEventArgs(collection))"><span class="fluent-icon">@Icon("settings")</span><span>@T("configure")</span></button>
                    <button @onclick="() => OnOpenCollectionInExplorer.InvokeAsync(new CollectionEventArgs(collection))"><span class="fluent-icon">@Icon("folder")</span><span>@T("openInExplorer")</span></button>
                    @RenderSortMenu($"collection:{collection.Id}")
                    <button @onclick="() => OnDuplicateCollection.InvokeAsync(new CollectionEventArgs(collection))"><span class="fluent-icon">@Icon("copy")</span><span>@T("duplicate")</span></button>
                    <button class="danger-menu" @onclick="() => OnDeleteCollectionItem.InvokeAsync(new CollectionEventArgs(collection))"><span class="fluent-icon">@Icon("delete")</span><span>@T("delete")</span></button>
                </div>
            </div>
        </div>
        @if (IsCollectionExpanded(collection) || IsSearching)
        {
            <div class="request-children">
                @foreach (var child in VisibleChildren(collection))
                {
                    @RenderCollectionNode(child)
                }
                @RenderCollectionRequests(collection, isRoot: false)
            </div>
        }
    </div>;

    private RenderFragment RenderCollectionRequests(ReadableCollection collection, bool isRoot) => @<div class="collection-requests @(isRoot ? "root-requests" : null)">
        @foreach (var request in SortedRequests(collection))
        {
            <div @key="request" class="@RequestRowClass(request)">
                <button class="request-main" @onclick="() => OnSelectRequest.InvokeAsync(new RequestEventArgs(collection, request))">
                    <span class="method tiny @request.Method.ToLowerInvariant()">@request.Method</span>
                    <strong>@request.Name</strong>
                </button>
                <div class='@RowActionsClass(MenuKey("request", request.Id), "request-actions")' @onclick:stopPropagation="true">
                    <button title="@T("more")" @onclick='() => ToggleMore(MenuKey("request", request.Id))'>···</button>
                    <div class="more-menu">
                        <button @onclick="() => OnSelectRequest.InvokeAsync(new RequestEventArgs(collection, request))"><span class="fluent-icon">@Icon("open")</span><span>@T("open")</span></button>
                        <button @onclick="() => OnDuplicateRequest.InvokeAsync(new RequestEventArgs(collection, request))"><span class="fluent-icon">@Icon("copy")</span><span>@T("duplicate")</span></button>
                        <button @onclick="() => OnOpenRequestDefault.InvokeAsync(new RequestEventArgs(collection, request))"><span class="fluent-icon">@Icon("document")</span><span>@T("openDefault")</span></button>
                        @if (MoveTargetCollections(collection).Count > 0)
                        {
                            <div class="menu-submenu">
                                <button class="submenu-trigger" type="button">@T("moveTo")</button>
                                <div class="submenu-panel">
                                    @foreach (var targetCollection in MoveTargetCollections(collection))
                                    {
                                        <button @key="targetCollection.Id" @onclick="() => OnMoveRequest.InvokeAsync(new RequestMoveEventArgs(collection, request, targetCollection))">@targetCollection.Name</button>
                                    }
                                </div>
                            </div>
                        }
                        <button class="danger-menu" @onclick="() => OnDeleteRequestItem.InvokeAsync(new RequestEventArgs(collection, request))"><span class="fluent-icon">@Icon("delete")</span><span>@T("delete")</span></button>
                    </div>
                </div>
            </div>
        }
    </div>;

    private bool Matches(string? value)
    {
        return string.IsNullOrWhiteSpace(Query)
            || (!string.IsNullOrWhiteSpace(value)
                && value.Contains(Query, StringComparison.OrdinalIgnoreCase));
    }

    private void ToggleQuickSwitch()
    {
        quickSwitchOpen = !quickSwitchOpen;
        openMenuKey = null;
        pendingDeleteWorkspacePath = null;
    }

    private async Task SelectWorkspaceFromQuickSwitch(WorkspaceOptionView workspace)
    {
        if (!workspace.IsUsable)
        {
            return;
        }

        quickSwitchOpen = false;
        await OnSelectWorkspace.InvokeAsync(new WorkspaceSelectedEventArgs(workspace.Path));
    }

    private async Task SelectWorkspaceIfUsable(string path)
    {
        if (!IsWorkspaceUsable(path))
        {
            return;
        }

        await OnSelectWorkspace.InvokeAsync(new WorkspaceSelectedEventArgs(NormalizeWorkspacePath(path)));
    }

    private void ToggleMore(string key, bool keepQuickSwitch = false)
    {
        if (!keepQuickSwitch)
        {
            quickSwitchOpen = false;
        }

        openMenuKey = string.Equals(openMenuKey, key, StringComparison.Ordinal) ? null : key;
        pendingDeleteWorkspacePath = null;
    }

    private async Task ConfirmDeleteWorkspace(string path)
    {
        pendingDeleteWorkspacePath = null;
        await OnDeleteWorkspaceFolder.InvokeAsync(new WorkspaceSelectedEventArgs(path));
    }

    private void SetSort(string scope, string sort)
    {
        if (scope == "collections")
        {
            collectionsSort = sort;
        }
        else if (scope == "specs")
        {
            specsSort = sort;
        }
        else if (scope.StartsWith("collection:", StringComparison.Ordinal))
        {
            requestSorts[scope["collection:".Length..]] = sort;
        }
    }

    private RenderFragment RenderSortMenu(string scope) => @<div class="menu-submenu">
        <button class="submenu-trigger" type="button"><span class="fluent-icon">@Icon("sort")</span><span>@T("sort")</span></button>
        <div class="submenu-panel">
            <button @onclick='() => SetSort(scope, "name")'><span class="fluent-icon">@Icon("text")</span><span>@T("sortByName")</span></button>
            <button @onclick='() => SetSort(scope, "size")'><span class="fluent-icon">@Icon("size")</span><span>@T("sortBySize")</span></button>
            <button @onclick='() => SetSort(scope, "updated")'><span class="fluent-icon">@Icon("clock")</span><span>@T("sortByUpdated")</span></button>
        </div>
    </div>;

    private void CloseFlyouts()
    {
        quickSwitchOpen = false;
        openMenuKey = null;
        pendingDeleteWorkspacePath = null;
    }

    private void ClearSearch()
    {
        searchText = string.Empty;
    }

    private void CollapseAllCollections()
    {
        expandedCollectionIds.Clear();
    }

    private void ToggleCollection(ReadableCollection collection)
    {
        if (!expandedCollectionIds.Add(collection.Id))
        {
            expandedCollectionIds.Remove(collection.Id);
        }
    }

    private async Task AddSubCollection(ReadableCollection collection)
    {
        expandedCollectionIds.Add(collection.Id);
        openMenuKey = null;
        await OnNewSubCollection.InvokeAsync(new CollectionEventArgs(collection));
    }

    private bool IsCollectionExpanded(ReadableCollection collection)
    {
        return expandedCollectionIds.Contains(collection.Id);
    }

    private void HandleSearchChanged(ChangeEventArgs args)
    {
        searchText = Convert.ToString(args.Value) ?? string.Empty;
    }

    private async Task HandleWorkspaceAutoInitializeChanged(ChangeEventArgs args)
    {
        await WorkspaceAutoInitializeChanged.InvokeAsync(args.Value is bool value && value);
    }

    private string WorkspaceClass(string path)
    {
        var classes = "workspace-option";
        if (string.Equals(NormalizeWorkspacePath(WorkspacePath), NormalizeWorkspacePath(path), StringComparison.OrdinalIgnoreCase))
        {
            classes += " active";
        }

        if (!IsWorkspaceUsable(path))
        {
            classes += " unavailable";
        }

        return classes;
    }

    private static string WorkspaceQuickRowClass(WorkspaceOptionView workspace, bool isActiveWorkspace)
    {
        var classes = isActiveWorkspace
            ? "quick-workspace-row active"
            : "quick-workspace-row";

        if (!workspace.IsUsable)
        {
            classes += " unavailable";
        }

        return classes;
    }

    private string RowActionsClass(string key, string? extra = null)
    {
        var value = string.Equals(openMenuKey, key, StringComparison.Ordinal)
            ? "row-actions open"
            : "row-actions";
        return string.IsNullOrWhiteSpace(extra) ? value : $"{value} {extra}";
    }

    private string TitleActionsClass(string key)
    {
        return string.Equals(openMenuKey, key, StringComparison.Ordinal)
            ? "title-actions open"
            : "title-actions";
    }

    private static string MenuKey(string scope, string id) => $"{scope}:{id}";

    private static bool IsWorkspaceUsable(string path)
    {
        return TryGetWorkspaceFile(path, out _);
    }

    private string WorkspaceMainTitle(WorkspaceOptionView workspace) => workspace.IsUsable
        ? T("switchWorkspace")
        : $"{T("workspaceUnavailableHint")}: {workspace.Status}";

    private string CollectionClass(ReadableCollection collection)
    {
        return ReferenceEquals(SelectedCollection, collection) ? "tree-row collection-row active" : "tree-row collection-row";
    }

    private string RequestRowClass(ReadableRequest request)
    {
        return SelectedRequest is not null && string.Equals(SelectedRequest.Id, request.Id, StringComparison.OrdinalIgnoreCase)
            ? "request-row active"
            : "request-row";
    }

    private string SpecificationClass(ReadableSpecification specification)
    {
        return string.Equals(TryFilePath, specification.Path, StringComparison.OrdinalIgnoreCase)
            ? "tree-row spec-row active"
            : "tree-row spec-row";
    }

    private static string WorkspaceLabel(string path)
    {
        var workspaceFile = GetWorkspaceFile(path);
        if (File.Exists(workspaceFile))
        {
            try
            {
                using var document = JsonDocument.Parse(File.ReadAllText(workspaceFile));
                if (document.RootElement.TryGetProperty("name", out var configuredName)
                    && !string.IsNullOrWhiteSpace(configuredName.GetString()))
                {
                    return configuredName.GetString()!;
                }
            }
            catch (Exception exception) when (exception is IOException or UnauthorizedAccessException or JsonException)
            {
            }
        }

        path = NormalizeWorkspacePath(path);
        var name = Path.GetFileName(path.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar));
        return string.IsNullOrWhiteSpace(name) ? path : name;
    }

    private static string NormalizeWorkspacePath(string path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return string.Empty;
        }

        path = path.Trim().Trim('"', '\'');
        if (Uri.TryCreate(path, UriKind.Absolute, out var uri) && uri.IsFile)
        {
            path = uri.LocalPath;
        }

        path = Environment.ExpandEnvironmentVariables(path);
        if (string.Equals(Path.GetFileName(path), "workspace.json", StringComparison.OrdinalIgnoreCase))
        {
            path = Path.GetDirectoryName(path) ?? path;
        }

        path = path.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);
        return Path.IsPathFullyQualified(path) ? Path.GetFullPath(path) : path;
    }

    private static string GetWorkspaceFile(string path)
    {
        path = NormalizeWorkspacePath(path);
        return string.IsNullOrWhiteSpace(path) ? string.Empty : Path.Combine(path, "workspace.json");
    }

    private static bool TryGetWorkspaceFile(string path, out string workspaceFile)
    {
        workspaceFile = GetWorkspaceFile(path);
        return !string.IsNullOrWhiteSpace(workspaceFile) && File.Exists(workspaceFile);
    }

    private string CollectionBadge(ReadableCollection collection)
    {
        var count = TotalRequestCount(collection);
        return count == 1
            ? $"1 {T("requestLower")}"
            : $"{count} {T("requestsLower")}";
    }

    private static int TotalRequestCount(ReadableCollection collection)
    {
        return collection.Requests.Count + collection.Children.Sum(TotalRequestCount);
    }

    private string SpecificationBadge(ReadableSpecification specification)
    {
        var format = specification.Format == ReadableSpecificationFormat.Unknown && !string.IsNullOrWhiteSpace(specification.Path)
            ? Path.GetExtension(specification.Path).TrimStart('.').ToUpperInvariant()
            : specification.Format.ToString();
        var source = specification.SourceType switch
        {
            ReadableSpecificationSourceType.RemoteEndpoint => "Remote",
            ReadableSpecificationSourceType.GitFile => "Git",
            _ => T("local")
        };
        return string.IsNullOrWhiteSpace(format) ? source : $"{source} · {format}";
    }

    private DateTime CollectionUpdatedAt(ReadableCollection collection)
    {
        var directory = CollectionDirectory(collection);
        return Directory.Exists(directory) ? Directory.GetLastWriteTimeUtc(directory) : DateTime.MinValue;
    }

    private long SpecificationSize(ReadableSpecification specification)
    {
        var path = SpecificationPathFor(specification);
        return File.Exists(path) ? new FileInfo(path).Length : 0L;
    }

    private DateTime SpecificationUpdatedAt(ReadableSpecification specification)
    {
        var path = SpecificationPathFor(specification);
        return File.Exists(path) ? File.GetLastWriteTimeUtc(path) : DateTime.MinValue;
    }

    private long RequestSize(ReadableCollection collection, ReadableRequest request)
    {
        var path = RequestPath(collection, request);
        return File.Exists(path) ? new FileInfo(path).Length : 0L;
    }

    private DateTime RequestUpdatedAt(ReadableCollection collection, ReadableRequest request)
    {
        var path = RequestPath(collection, request);
        return File.Exists(path) ? File.GetLastWriteTimeUtc(path) : DateTime.MinValue;
    }

    private string CollectionDirectory(ReadableCollection collection)
    {
        return string.IsNullOrWhiteSpace(collection.RequestDirectory)
            ? Path.Combine(WorkspacePath, "collections", ToFileName(collection.Name))
            : Path.Combine(WorkspacePath, collection.RequestDirectory);
    }

    private string RequestPath(ReadableCollection collection, ReadableRequest request)
    {
        return string.IsNullOrWhiteSpace(request.SourcePath)
            ? Path.Combine(CollectionDirectory(collection), $"{ToFileName(request.Name)}.json")
            : Path.Combine(WorkspacePath, request.SourcePath);
    }

    private string SpecificationPathFor(ReadableSpecification specification)
    {
        if (!string.IsNullOrWhiteSpace(specification.Path))
        {
            return Path.IsPathRooted(specification.Path)
                ? specification.Path
                : Path.Combine(WorkspacePath, specification.Path);
        }

        if (!string.IsNullOrWhiteSpace(specification.NormalizedPath))
        {
            return Path.IsPathRooted(specification.NormalizedPath)
                ? specification.NormalizedPath
                : Path.Combine(WorkspacePath, specification.NormalizedPath);
        }

        return string.Empty;
    }

    private static string ToFileName(string value)
    {
        var invalid = Path.GetInvalidFileNameChars();
        var sanitized = new string(value.Select(character => invalid.Contains(character) ? '-' : character).ToArray());
        return string.IsNullOrWhiteSpace(sanitized) ? "item" : sanitized;
    }

    private static IEnumerable<ReadableCollection> EnumerateCollections(IEnumerable<ReadableCollection> collections)
    {
        foreach (var collection in collections)
        {
            yield return collection;
            foreach (var child in EnumerateCollections(collection.Children))
            {
                yield return child;
            }
        }
    }

    private static bool IsRootCollection(ReadableCollection collection)
    {
        var directory = collection.RequestDirectory?.Replace('\\', '/').TrimEnd('/');
        return string.Equals(collection.Id, "__collections_root__", StringComparison.OrdinalIgnoreCase)
            || string.Equals(directory, "collections", StringComparison.OrdinalIgnoreCase);
    }

