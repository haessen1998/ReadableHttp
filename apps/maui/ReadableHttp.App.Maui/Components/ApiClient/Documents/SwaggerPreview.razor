@using ReadableHttp.Try

<section class="swagger-stage">
    <header class="swagger-header">
        <div class="swagger-title">
            <span class="spec-icon">{} </span>
            <div>
                <h1>@DocumentTitle</h1>
                <p>@TryFilePath</p>
            </div>
            <span class="oas-pill">OAS 3.1</span>
            <span class="version-pill">v1</span>
        </div>
        <div class="swagger-links">
            <button @onclick="OnImportAsCollection">Import Collection</button>
            <button @onclick="OnShowRaw">Raw</button>
        </div>
    </header>
    <div class="swagger-search">
        <span>⌕</span>
        <input placeholder="Filter endpoints..." />
        <strong>@Operations.Count endpoints</strong>
    </div>
    @if (Operations.Count == 0)
    {
        <div class="empty-panel">
            <strong>No operations loaded</strong>
            <span>@Path.GetFileName(TryFilePath)</span>
            <button class="accent-button" @onclick="OnLoadTryDocument">Preview API</button>
        </div>
    }
    else
    {
        <div class="swagger-groups">
            @foreach (var group in Operations.GroupBy(operation => OperationTag(operation.Path)))
            {
                <section @key="group.Key" class="endpoint-group">
                    <header>
                        <span class="tag-dot"></span>
                        <strong>@group.Key</strong>
                        <small>@group.Count()</small>
                    </header>
                    @foreach (var operation in group)
                    {
                        var operationKey = OperationKey(operation);
                        <article @key="operationKey" class="@EndpointCardClass(operation)">
                            <button class="endpoint-summary" @onclick="() => OnToggleEndpoint.InvokeAsync(operation)">
                                <span class="method @operation.Method.ToLowerInvariant()">@operation.Method</span>
                                <span class="endpoint-path">@operation.Path</span>
                                <span class="endpoint-name">@operation.Name</span>
                                <span class="lock-mark">@(ExpandedOperationKey == operationKey ? "▴" : "▾")</span>
                            </button>
                            @if (ExpandedOperationKey == operationKey)
                            {
                                <div class="endpoint-detail">
                                    <p>@OperationDescription(operation)</p>
                                    <div class="endpoint-section">
                                        <span>Parameters</span>
                                        <table class="spec-table">
                                            <thead>
                                                <tr><th>Name</th><th>In</th><th>Type</th><th>Req.</th><th>Description</th></tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var parameter in OperationParameters(operation))
                                                {
                                                    <tr @key="parameter">
                                                        <td>@parameter.Name</td>
                                                        <td><i class="in-badge @parameter.Location">@parameter.Location</i></td>
                                                        <td><i class="type-pill string">@parameter.Type</i></td>
                                                        <td>@(parameter.Required ? "●" : "○")</td>
                                                        <td>@parameter.Description</td>
                                                    </tr>
                                                }
                                                @if (OperationParameters(operation).Count == 0)
                                                {
                                                    <tr><td colspan="5">No parameters declared on this operation.</td></tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="endpoint-section">
                                        <span>Responses</span>
                                        <div class="response-list">
                                            <div><strong class="ok">2xx</strong><span>Response schema is not available in the normalized try model.</span><em>@ResponseHint(operation)</em></div>
                                            @if (RequiresAuth(operation))
                                            {
                                                <div><strong class="warn">401</strong><span>Authentication may be required.</span><em>Auth</em></div>
                                            }
                                        </div>
                                    </div>
                                    <div class="endpoint-actions">
                                        <button @onclick="() => OnSelectOperation.InvokeAsync(operation)">Try</button>
                                    </div>
                                </div>
                            }
                        </article>
                    }
                </section>
            }
        </div>
    }
</section>

@code {
    [Parameter] public string DocumentTitle { get; set; } = string.Empty;
    [Parameter] public string TryFilePath { get; set; } = string.Empty;
    [Parameter] public string ActiveSource { get; set; } = string.Empty;
    [Parameter] public IReadOnlyList<ReadableTryOperation> Operations { get; set; } = [];
    [Parameter] public string? ExpandedOperationKey { get; set; }
    [Parameter] public EventCallback OnShowRaw { get; set; }
    [Parameter] public EventCallback OnImportAsCollection { get; set; }
    [Parameter] public EventCallback OnLoadTryDocument { get; set; }
    [Parameter] public EventCallback<ReadableTryOperation> OnToggleEndpoint { get; set; }
    [Parameter] public EventCallback<ReadableTryOperation> OnSelectOperation { get; set; }

    private string EndpointCardClass(ReadableTryOperation operation)
    {
        var key = OperationKey(operation);
        var active = ExpandedOperationKey == key ? " expanded" : string.Empty;
        return $"endpoint-card {operation.Method.ToLowerInvariant()}{active}";
    }

    private static string OperationKey(ReadableTryOperation operation) => $"{operation.Method}:{operation.Path}:{operation.Name}";

    private static string OperationTag(string path)
    {
        var segment = path.Split('/', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
        return string.IsNullOrWhiteSpace(segment)
            ? "General"
            : char.ToUpperInvariant(segment[0]) + segment[1..];
    }

    private static IReadOnlyList<SwaggerParameterRow> OperationParameters(ReadableTryOperation operation)
    {
        var rows = new List<SwaggerParameterRow>();
        rows.AddRange(ExtractPathParameters(operation.Path));
        rows.AddRange(operation.Request.Query.Select(item => new SwaggerParameterRow(
            item.Name,
            "query",
            "string",
            false,
            string.IsNullOrWhiteSpace(item.Value) ? "Query parameter" : item.Value ?? string.Empty)));
        rows.AddRange(operation.Request.Headers.Select(item => new SwaggerParameterRow(
            item.Name,
            "header",
            "string",
            item.Name.StartsWith("Authorization", StringComparison.OrdinalIgnoreCase),
            string.IsNullOrWhiteSpace(item.Value) ? "Header" : item.Value ?? string.Empty)));

        if (operation.Request.Body is { Type: not ReadableBodyType.None } body)
        {
            rows.Add(new SwaggerParameterRow("body", "body", body.Type.ToString(), true, body.ContentType ?? "Request body"));
        }

        return rows;
    }

    private static IEnumerable<SwaggerParameterRow> ExtractPathParameters(string path)
    {
        foreach (var segment in path.Split('/', StringSplitOptions.RemoveEmptyEntries))
        {
            if (segment.Length > 2 && segment[0] == '{' && segment[^1] == '}')
            {
                yield return new SwaggerParameterRow(segment[1..^1], "path", "string", true, "Path parameter");
            }
        }
    }

    private static string OperationDescription(ReadableTryOperation operation)
    {
        return string.IsNullOrWhiteSpace(operation.Summary)
            ? $"{operation.Name} endpoint generated from try model. Use Try to edit parameters, body, auth, and send it."
            : operation.Summary;
    }

    private static string ResponseHint(ReadableTryOperation operation)
    {
        return operation.Request.Body?.ContentType ?? operation.Request.Body?.Type.ToString() ?? operation.Name;
    }

    private static bool RequiresAuth(ReadableTryOperation operation)
    {
        return operation.Request.Auth?.Type is not null and not ReadableAuthType.None
            || operation.Request.Headers.Any(header => header.Name.Contains("Authorization", StringComparison.OrdinalIgnoreCase));
    }

    private sealed record SwaggerParameterRow(string Name, string Location, string Type, bool Required, string Description);
}
