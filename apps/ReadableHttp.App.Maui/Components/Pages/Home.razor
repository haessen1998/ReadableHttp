@page "/"
@implements IDisposable
@inject ApiClientWorkspaceState State

<PageTitle>ReadableHttp</PageTitle>

<RequestWorkspace Method="@State.Method"
                  MethodChanged="@State.SetMethod"
                  Url="@State.Url"
                  UrlChanged="@State.SetUrl"
                  BodyText="@State.BodyText"
                  BodyTextChanged="@State.SetBodyText"
                  IsSending="@State.IsSending"
                  ViewMode="@State.ViewMode"
                  RawContent="@State.RawContent"
                  RequestTab="@State.RequestTab"
                  WorkspaceName="@State.WorkspaceName"
                  ActiveSource="@State.ActiveSource"
                  OperationCount="@State.Operations.Count"
                  UseSystemProxy="@State.UseSystemProxy"
                  ResponseNodePath="@State.ResponseNodePath"
                  StatusClass="@State.StatusClass"
                  StatusText="@State.StatusText"
                  ResponseText="@State.ResponseText"
                  PipelineTotalLabel="@State.PipelineTotalLabel"
                  PipelinePhases="@State.PipelinePhases"
                  ResponseNodeKeys="@State.ResponseNodeKeys"
                  SelectedResponseText="@State.SelectedResponseText"
                  RequestTabs="@State.RequestTabs"
                  ActiveRequestTabId="@State.ActiveRequestTabId"
                  ActiveRequestOrigin="@State.ActiveRequestTab?.Origin"
                  SettingsDraft="@State.SettingsDraft"
                  OnSend="@State.SendAsync"
                  OnSaveRequest="@State.SaveActiveRequestAsync"
                  OnSaveRequestAsNew="@State.SaveActiveRequestAsNewAsync"
                  OnSaveSettings="@State.SaveSettings"
                  ThemeModeChanged="@State.SetDraftThemeMode"
                  ProxyModeChanged="@State.SetDraftProxyMode"
                  CustomProxyUrlChanged="@State.SetDraftCustomProxyUrl"
                  CustomProxyUsernameChanged="@State.SetDraftCustomProxyUsername"
                  CustomProxyPasswordChanged="@State.SetDraftCustomProxyPassword"
                  DevToolsEnabledChanged="@State.SetDraftDevToolsEnabled"
                  LanguageChanged="@State.SetDraftLanguage"
                  OnNewScratchRequest="@State.NewScratchRequest"
                  OnSelectOpenTab="@State.SelectRequestTab"
                  OnCloseOpenTab="@State.CloseRequestTab"
                  OnSetRequestTab="@State.SetRequestTab"
                  OnSelectResponseNode="@State.SelectResponseNode">
    <PreviewContent>
        <SwaggerPreview DocumentTitle="@State.DocumentTitle"
                        TryFilePath="@State.TryFilePath"
                        ActiveSource="@State.ActiveSource"
                        Operations="@State.Operations"
                        ExpandedOperationKey="@State.ExpandedOperationKey"
                        OnShowRaw="@State.ShowRaw"
                        OnLoadTryDocument="@State.LoadTryDocumentAsync"
                        OnToggleEndpoint="@State.ToggleEndpoint"
                        OnSelectOperation="@State.SelectOperation" />
    </PreviewContent>
</RequestWorkspace>

@code {
    protected override void OnInitialized()
    {
        State.Changed += HandleStateChanged;
    }

    private async void HandleStateChanged()
    {
        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception exception)
        {
            await DispatchExceptionAsync(exception);
        }
    }

    public void Dispose()
    {
        State.Changed -= HandleStateChanged;
    }
}
